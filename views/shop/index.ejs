<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container">

  <% if (hero.enabled) { %>
    <section class="cc-hero">
      <div class="cc-hero-text">
        <% if (hero.eyebrow) { %><span class="cc-hero-eyebrow"><%= hero.eyebrow %></span><% } %>
        <% if (hero.heading) { %><h1><%= hero.heading %></h1><% } %>
        <% if (hero.subheading) { %><p><%= hero.subheading %></p><% } %>
        <% if (hero.ctaLabel && hero.ctaHref) { %>
          <a href="<%= hero.ctaHref %>" class="cc-btn cc-btn-primary"><%= hero.ctaLabel %></a>
        <% } %>
      </div>
      <div class="cc-hero-art" aria-hidden="true">
        <% if (hero.tile1) { %><div class="cc-hero-tile cc-hero-tile-1" style="background-image: url('<%= hero.tile1 %>')"></div><% } %>
        <% if (hero.tile2) { %><div class="cc-hero-tile cc-hero-tile-2" style="background-image: url('<%= hero.tile2 %>')"></div><% } %>
        <% if (hero.tile3) { %><div class="cc-hero-tile cc-hero-tile-3" style="background-image: url('<%= hero.tile3 %>')"></div><% } %>
      </div>
    </section>
  <% } %>

  <% if (banners && banners.length) { %>
    <!-- Promo banner carousel — admin-managed under /admin/settings.
         Uses Bootstrap's carousel (already loaded via foot.ejs) for
         autoplay, swipe gestures on touch, prev/next, and indicators. -->
    <div id="homeBanners" class="cc-banners carousel slide" data-bs-ride="carousel" data-bs-interval="4500" data-bs-pause="hover">
      <div class="carousel-inner">
        <% banners.forEach((b, i) => { %>
          <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
            <% const wrapTag = b.linkUrl ? 'a' : 'div'; %>
            <% if (b.linkUrl) { %>
              <a href="<%= b.linkUrl %>" target="_blank" rel="noopener" class="cc-banner-slide">
            <% } else { %>
              <div class="cc-banner-slide">
            <% } %>
              <img src="<%= b.imageUrl %>" alt="<%= b.caption || '' %>" loading="lazy">
              <% if (b.caption || b.subcaption) { %>
                <div class="cc-banner-caption">
                  <% if (b.caption) { %><h3 class="cc-banner-title"><%= b.caption %></h3><% } %>
                  <% if (b.subcaption) { %><p class="cc-banner-subtitle"><%= b.subcaption %></p><% } %>
                </div>
              <% } %>
            <% if (b.linkUrl) { %></a><% } else { %></div><% } %>
          </div>
        <% }); %>
      </div>
      <% if (banners.length > 1) { %>
        <button class="carousel-control-prev" type="button" data-bs-target="#homeBanners" data-bs-slide="prev" aria-label="Previous">
          <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#homeBanners" data-bs-slide="next" aria-label="Next">
          <span class="carousel-control-next-icon" aria-hidden="true"></span>
        </button>
        <div class="carousel-indicators">
          <% banners.forEach((b, i) => { %>
            <button type="button" data-bs-target="#homeBanners" data-bs-slide-to="<%= i %>" class="<%= i === 0 ? 'active' : '' %>" aria-label="Banner <%= i + 1 %>"></button>
          <% }); %>
        </div>
      <% } %>
    </div>
  <% } %>

  <% if (categories && categories.length) { %>
    <div class="cc-section-head">
      <h2>Browse categories</h2>
    </div>
    <div class="cc-chips">
      <a class="cc-chip <%= activeCategorySlug === 'all' ? 'is-active' : '' %>" href="/">All</a>
      <% categories.forEach(c => { %>
        <a class="cc-chip <%= activeCategorySlug === c.slug ? 'is-active' : '' %>" href="/?category=<%= c.slug %>"><%= c.name %></a>
      <% }); %>
    </div>
  <% } %>

  <% if (featured && featured.length) { %>
    <div class="cc-section-head">
      <h2>Featured</h2>
      <span class="muted">Hand-picked by the team</span>
    </div>
    <div class="cc-grid cc-grid-rail">
      <% featured.forEach(product => { %>
        <%- include('../partials/product-card', { product, isPpzMember }) %>
      <% }); %>
    </div>
  <% } %>

  <% if (newProducts && newProducts.length) { %>
    <div class="cc-section-head">
      <h2>New arrivals</h2>
      <span class="muted">Added in the last 7 days</span>
    </div>
    <div class="cc-grid cc-grid-rail">
      <% newProducts.forEach(product => { %>
        <%- include('../partials/product-card', { product, isPpzMember }) %>
      <% }); %>
    </div>
  <% } %>

  <div class="cc-section-head" id="catalogue">
    <h2><%= activeCategorySlug && activeCategorySlug !== 'all' ? 'Filtered products' : 'All products' %></h2>
    <span class="muted"><%= products.length %> item<%= products.length === 1 ? '' : 's' %></span>
  </div>

  <% if (!products.length) { %>
    <div class="cc-empty">No products yet. Sign in as admin and add some, or set <code>SEED_SAMPLES=true</code>.</div>
  <% } else { %>
    <div class="cc-grid">
      <% products.forEach(product => { %>
        <%- include('../partials/product-card', { product, isPpzMember }) %>
      <% }); %>
    </div>
  <% } %>
</div>
<%- include('../partials/foot') %>
