<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container" style="max-width: 520px;">
  <p class="mt-4 mb-2"><a href="/orders" class="text-muted">← Back to orders</a></p>

  <div class="admin-panel" style="border-radius: 18px;">
    <div class="panel-body padded" style="text-align:center;">
      <div class="text-muted" style="font-size:.9rem; letter-spacing:.04em; text-transform:uppercase;">
        Collection QR
      </div>
      <h2 style="font-weight:700; margin:6px 0 18px; letter-spacing:-0.01em;">
        <%= order.number %>
      </h2>

      <% if (qrSvg) { %>
        <div style="display:flex; justify-content:center; padding: 12px;">
          <div style="background:#fff; padding:18px; border-radius:14px; box-shadow: 0 1px 3px rgba(0,0,0,.06);">
            <%- qrSvg %>
          </div>
        </div>

        <p class="text-muted mt-3" style="font-size:.92rem;">
          Show this QR at the collection counter. Staff will scan it and
          mark your order as collected.
        </p>

        <% if (bundleOrders && bundleOrders.length > 1) { %>
          <div class="mt-3" style="border:1px solid var(--line); border-radius:12px; padding:12px; background: var(--surface-soft); text-align:left;">
            <div class="text-muted" style="font-size:.78rem; text-transform:uppercase; letter-spacing:.04em;">
              This QR also collects
            </div>
            <ul class="mb-0 mt-1" style="padding-left:18px;">
              <% bundleOrders.forEach(b => { %>
                <% if (b.id !== order.id) { %>
                  <li><%= b.number %></li>
                <% } %>
              <% }); %>
            </ul>
          </div>
        <% } %>
      <% } else { %>
        <div style="display:flex; justify-content:center; padding: 24px 12px;">
          <div style="background: var(--surface-soft); border:1px dashed var(--line); border-radius:14px; padding: 28px 18px; max-width: 320px;">
            <div style="font-size: 2rem; line-height: 1; margin-bottom: 8px;">⏳</div>
            <strong>Your bundle is being prepared</strong>
            <p class="text-muted mt-2 mb-0" style="font-size:.9rem;">
              Once the team has packed your order(s) you'll see your
              pickup QR right here. We'll notify you the moment it's ready.
            </p>
          </div>
        </div>
      <% } %>

      <hr class="mt-3 mb-3">

      <dl class="profile-dl" style="text-align:left;">
        <dt>Status</dt>
        <dd><span class="badge-status <%= order.status %>"><%= order.status %></span></dd>
        <dt>Total</dt>
        <dd>
          $<%= (order.totalCents/100).toFixed(2) %><% if (order.pointsTotal > 0) { %>
            + <%= Number(order.pointsTotal).toLocaleString() %> pts<% } %>
        </dd>
        <% if (order.collectionPoints && order.collectionPoints.length) { %>
          <dt>Pick up at</dt>
          <dd>
            <% order.collectionPoints.forEach((cp, idx) => { %>
              <% if (idx > 0) { %><br><% } %>
              <strong><%= cp.vendorName || 'PPZ Collection Point' %></strong>
              <% if (cp.line1) { %><div><%= cp.line1 %></div><% } %>
              <% if (cp.line2) { %><div><%= cp.line2 %></div><% } %>
              <% if (cp.contact) { %><div class="text-muted">Contact <%= cp.contact %></div><% } %>
              <% if (cp.hours) { %><div class="text-muted">Hours <%= cp.hours %></div><% } %>
            <% }); %>
          </dd>
        <% } %>
      </dl>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
