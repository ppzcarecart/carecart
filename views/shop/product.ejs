<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container">
  <% if (!product) { %>
    <div class="cc-empty mt-4">Product not found.</div>
  <% } else { %>
    <nav class="mt-3 mb-2" style="font-size:.9rem; color: var(--ink-soft);">
      <a href="/" class="text-decoration-none">Shop</a>
      <% if (product.category) { %>
        <span class="mx-2">›</span>
        <span><%= product.category.name %></span>
      <% } %>
    </nav>

    <div class="cc-detail">
      <div class="cc-gallery">
        <%- include('../partials/product-thumb', { product }) %>
      </div>
      <div class="cc-info">
        <%
        const NEW_WINDOW_MS = 7 * 24 * 60 * 60 * 1000;
        const isNew = product.createdAt && (Date.now() - new Date(product.createdAt).getTime() < NEW_WINDOW_MS);
        %>
        <div class="cc-info-badges">
          <% if (product.featured) { %><span class="cc-badge cc-badge-featured">Featured</span><% } %>
          <% if (isNew) { %><span class="cc-badge cc-badge-new">New</span><% } %>
        </div>
        <h1><%= product.name %></h1>
        <div class="vendor-tag">by <%= product.vendor && (product.vendor.vendorStoreName || product.vendor.name) || 'Vendor' %></div>
        <div class="price-row">
          <span class="amount">$<%= (product.priceCents/100).toFixed(2) %></span>
          <% if (product.pointsPrice) { %>
            <span class="points"><%= product.pointsPrice %> pts</span>
          <% } %>
        </div>
        <% if (product.description) { %>
          <p class="desc"><%= product.description %></p>
        <% } %>

        <% if (product.variants && product.variants.length) { %>
          <div class="field">
            <label for="variantId">Variant</label>
            <select id="variantId" class="form-control">
              <option value="">— Choose —</option>
              <% product.variants.forEach(v => { %>
                <option value="<%= v.id %>" <%= v.stock === 0 ? 'disabled' : '' %>>
                  <%= v.name %><% if (v.priceCentsOverride) { %> · $<%= (v.priceCentsOverride/100).toFixed(2) %><% } %>
                  <%= v.stock === 0 ? '(sold out)' : `(stock: ${v.stock})` %>
                </option>
              <% }); %>
            </select>
          </div>
        <% } %>

        <div class="field">
          <label for="qty">Quantity</label>
          <input id="qty" type="number" min="1" value="1" class="form-control" style="max-width:140px;">
        </div>

        <div class="cc-actions">
          <% if (user) { %>
            <button class="cc-btn cc-btn-primary" onclick="ppz.addToCart('<%= product.id %>', 'price')">
              Add to cart · $<%= (product.priceCents/100).toFixed(2) %>
            </button>
            <% if (product.pointsPrice) { %>
              <button class="cc-btn cc-btn-outline" onclick="ppz.addToCart('<%= product.id %>', 'points')">
                Use <%= product.pointsPrice %> pts
              </button>
            <% } %>
          <% } else { %>
            <a href="/login" class="cc-btn cc-btn-primary">Sign in to buy</a>
          <% } %>
        </div>
      </div>
    </div>
  <% } %>
</div>
<%- include('../partials/foot') %>
