<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container">
  <% if (!product) { %>
    <div class="cc-empty mt-4">Product not found.</div>
  <% } else { %>
    <nav class="mt-3 mb-2" style="font-size:.9rem; color: var(--ink-soft);">
      <a href="/" class="text-decoration-none">Shop</a>
      <% if (product.category) { %>
        <span class="mx-2">›</span>
        <span><%= product.category.name %></span>
      <% } %>
    </nav>

    <div class="cc-detail">
      <div class="cc-gallery"
        <% if (product.images && product.images[0]) { %>
        onclick="ppz.openZoom('<%= product.images[0].url %>', '<%= product.name.replace(/'/g, '&#39;') %>')"
        role="button"
        tabindex="0"
        aria-label="Zoom in on product image"
        title="Click to zoom"
        <% } %>
      >
        <%- include('../partials/product-thumb', { product }) %>
      </div>
      <div class="cc-info">
        <%
        const NEW_WINDOW_MS = 7 * 24 * 60 * 60 * 1000;
        const isNew = product.createdAt && (Date.now() - new Date(product.createdAt).getTime() < NEW_WINDOW_MS);
        const ppzMember = !!isPpzMember;
        const showPpzPrice = ppzMember && product.ppzPriceCents != null;
        const cashCents = showPpzPrice ? product.ppzPriceCents : product.priceCents;
        const showStrike = showPpzPrice && product.ppzPriceCents < product.priceCents;
        const ptsValue = (product.effectivePointsPrice != null) ? product.effectivePointsPrice : (ppzMember ? product.pointsPrice : null);
        const showPoints = ppzMember && ptsValue;
        // Hybrid offset preview: points convert to a discount via
        // pointsPerDollar, capped at the buyer-applicable cash price.
        // The remainder is paid in cash. Mirrors splitUnit() in the
        // cart service so the preview matches what they'll actually be
        // billed.
        let redeemCashCents = cashCents;
        let redeemPoints = 0;
        if (showPoints && pointsPerDollar > 0) {
          const pointsValueCents = Math.round(ptsValue * 100 / pointsPerDollar);
          const discountCents = Math.min(pointsValueCents, cashCents);
          redeemCashCents = cashCents - discountCents;
          redeemPoints = Math.round(discountCents * pointsPerDollar / 100);
        }
        %>
        <div class="cc-info-badges">
          <% if (product.featured) { %><span class="cc-badge cc-badge-featured">Featured</span><% } %>
          <% if (isNew) { %><span class="cc-badge cc-badge-new">New</span><% } %>
          <% if (showPpzPrice) { %><span class="cc-badge cc-badge-ppz">PPZ Member Price</span><% } %>
        </div>
        <h1><%= product.name %></h1>
        <div class="vendor-tag">by <%= product.vendor && (product.vendor.vendorStoreName || product.vendor.name) || 'Vendor' %></div>
        <div class="price-row">
          <span class="amount">$<%= (cashCents/100).toFixed(2) %></span>
          <% if (showStrike) { %>
            <span class="amount-strike">$<%= (product.priceCents/100).toFixed(2) %></span>
          <% } %>
          <% if (showPoints) { %>
            <span class="points">
              or <%= redeemPoints %> pts<% if (redeemCashCents > 0) { %> at $<%= (redeemCashCents/100).toFixed(2) %><% } %>
            </span>
          <% } %>
        </div>
        <% if (product.description) { %>
          <p class="desc"><%= product.description %></p>
        <% } %>

        <% if (product.variants && product.variants.length) { %>
          <div class="field">
            <label for="variantId">Variant</label>
            <select id="variantId" class="form-control"
              onchange="ppz.swapGalleryToVariant(this)">
              <option value="">— Choose —</option>
              <% product.variants.forEach(v => { %>
                <option value="<%= v.id %>"
                  data-image-url="<%= v.imageUrl || '' %>"
                  <%= v.stock === 0 ? 'disabled' : '' %>>
                  <%= v.name %><% if (v.priceCentsOverride) { %> · $<%= (v.priceCentsOverride/100).toFixed(2) %><% } %>
                  <%= v.stock === 0 ? '(sold out)' : `(stock: ${v.stock})` %>
                </option>
              <% }); %>
            </select>
          </div>
        <% } %>

        <div class="field">
          <label for="qty">Quantity</label>
          <input id="qty" type="number" min="1" value="1" class="form-control" style="max-width:140px;">
        </div>

        <div class="cc-actions">
          <% if (user) { %>
            <button class="cc-btn cc-btn-primary" onclick="ppz.addToCart('<%= product.id %>', 'price')">
              <%= showPpzPrice ? 'Buy at PPZ price' : 'Add to cart' %> · $<%= (cashCents/100).toFixed(2) %>
            </button>
            <% if (showPoints) { %>
              <button class="cc-btn cc-btn-outline" onclick="ppz.addToCart('<%= product.id %>', 'points')">
                <% if (redeemCashCents === 0) { %>
                  Redeem with <%= redeemPoints %> pts
                <% } else { %>
                  Redeem <%= redeemPoints %> pts at $<%= (redeemCashCents/100).toFixed(2) %>
                <% } %>
              </button>
            <% } %>
          <% } else { %>
            <a href="/login" class="cc-btn cc-btn-primary">Sign in to buy</a>
          <% } %>
        </div>
      </div>
    </div>
  <% } %>
</div>

<!-- Image zoom lightbox. Mobile gets native pinch-zoom via
     touch-action:pinch-zoom on the scroll container. Desktop click on
     the inner image toggles between fit-to-viewport and 1:1 natural
     size (panning via the same scroll container). ESC + backdrop
     click + close button all dismiss. -->
<div class="cc-zoom" id="ccZoom" hidden>
  <button type="button" class="cc-zoom-close" aria-label="Close zoom" onclick="ppz.closeZoom()">×</button>
  <div class="cc-zoom-scroll" id="ccZoomScroll" onclick="ppz.closeZoom(event)">
    <img class="cc-zoom-img" id="ccZoomImg" alt="" onclick="event.stopPropagation(); ppz.toggleZoomScale(this)">
  </div>
</div>

<%- include('../partials/foot') %>
