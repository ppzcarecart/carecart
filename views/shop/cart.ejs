<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container">
  <h1 class="mt-4 mb-1" style="font-weight:700; letter-spacing:-0.01em;">Your cart</h1>
  <p class="text-muted">Review your items, choose how to receive them, then checkout.</p>

  <% if (!summary.cart.items.length) { %>
    <div class="cc-empty mt-4">
      Your cart is empty. <a href="/">Continue shopping</a>.
    </div>
  <% } else { %>
    <div class="cc-cart-grid">
      <div>
        <div class="cc-cart-list mb-3">
          <% summary.lines.forEach(l => { %>
            <div class="cc-cart-row">
              <div class="thumb">
                <%- include('../partials/product-thumb', { product: l.item.product }) %>
              </div>
              <div class="meta">
                <div class="name"><%= l.item.product.name %></div>
                <% if (l.item.variant) { %>
                  <div class="variant"><%= l.item.variant.name %></div>
                <% } %>
                <div class="variant text-uppercase" style="font-size:.7rem; letter-spacing:.06em;">
                  Pay with <%= l.item.pricingMode === 'points' ? 'points' : 'cash' %>
                  <% if (l.deliveryFeeCents > 0) { %>
                    · delivery $<%= (l.deliveryFeeCents/100).toFixed(2) %>
                  <% } %>
                </div>
              </div>
              <div class="qty">
                <input type="number" min="1" value="<%= l.item.quantity %>"
                  onchange="ppz.updateCart('<%= l.item.id %>', this.value)">
              </div>
              <div class="line">
                <% if (l.item.pricingMode === 'price') { %>
                  $<%= (l.lineCents/100).toFixed(2) %>
                <% } else { %>
                  <%= l.linePoints %> pts
                <% } %>
                <button class="cc-btn cc-btn-ghost" style="padding:4px 8px; font-size:.8rem; margin-left:8px;"
                  onclick="ppz.removeCart('<%= l.item.id %>')">Remove</button>
              </div>
            </div>
          <% }); %>
        </div>

        <div class="admin-panel mb-3">
          <div class="panel-head">
            <h3 style="font-size:1rem;">Fulfilment</h3>
          </div>
          <div class="panel-body padded">
            <div class="d-flex flex-wrap gap-2 mb-3">
              <button type="button"
                class="cc-btn <%= summary.fulfilmentMethod === 'delivery' ? 'cc-btn-primary' : 'cc-btn-outline' %>"
                <%= summary.deliveryEnabled ? '' : 'disabled' %>
                onclick="ppz.pickFulfilment('delivery')">
                Delivery
                <% if (summary.deliveryEnabled) { %>· $<%= (summary.deliveryFeeCents/100).toFixed(2) %><% } else { %>(disabled)<% } %>
              </button>
              <button type="button"
                class="cc-btn <%= summary.fulfilmentMethod === 'collection' ? 'cc-btn-primary' : 'cc-btn-outline' %>"
                onclick="ppz.pickFulfilment('collection')">
                Self-collection
              </button>
            </div>

            <% if (summary.fulfilmentMethod === 'delivery') { %>
              <form id="shippingForm" onsubmit="event.preventDefault();">
                <div class="mb-2"><label>Delivery address</label>
                  <input class="form-control" name="line1"
                    value="<%= defaultShipping ? (defaultShipping.line1 || '') : '' %>" placeholder="Street, unit number" required>
                </div>
                <div class="row">
                  <div class="col-md-6 mb-2"><label>Postal code</label>
                    <input class="form-control" name="postalCode" inputmode="numeric" maxlength="6"
                      value="<%= defaultShipping ? (defaultShipping.postalCode || '') : '' %>" required>
                  </div>
                  <div class="col-md-6 mb-2"><label>Country</label>
                    <select class="form-select" disabled><option>Singapore</option></select>
                  </div>
                </div>
                <p class="text-muted" style="font-size:.85rem; margin-top:6px;">
                  We'll capture your address when you checkout.
                </p>
              </form>
            <% } else { %>
              <p class="text-muted" style="font-size:.9rem; margin:0 0 10px;">
                Pick up from <%= summary.collectionPoints.length === 1 ? 'this location' : 'these locations' %>:
              </p>
              <% if (!summary.collectionPoints.length) { %>
                <div class="cc-empty" style="margin:0;">No collection point configured. Ask admin to set one in /admin/settings.</div>
              <% } %>
              <% summary.collectionPoints.forEach(cp => { %>
                <div class="profile-address" style="border-left:3px solid var(--brand); padding-left:12px; margin-bottom:10px;">
                  <strong><%= cp.vendorName || 'PPZ Collection Point' %></strong>
                  <% if (cp.source === 'vendor') { %>
                    <span class="ctype-tag ctype-ppz" style="margin-left:6px;">Vendor location</span>
                  <% } %>
                  <div><%= cp.line1 || '(address not set)' %></div>
                  <% if (cp.line2) { %><div><%= cp.line2 %></div><% } %>
                  <% if (cp.postalCode) { %><div class="text-muted">Postal <%= cp.postalCode %></div><% } %>
                  <% if (cp.contact) { %><div class="text-muted">Contact <%= cp.contact %></div><% } %>
                  <% if (cp.hours) { %><div class="text-muted">Hours <%= cp.hours %></div><% } %>
                </div>
              <% }); %>
            <% } %>
          </div>
        </div>
      </div>

      <aside class="cc-summary">
        <h3>Order summary</h3>
        <div class="row">
          <span>Cash subtotal</span>
          <span>$<%= (summary.subtotalCents/100).toFixed(2) %></span>
        </div>
        <% if (summary.fulfilmentMethod === 'delivery' && summary.deliveryFeeCents > 0) { %>
          <div class="row">
            <span>Delivery</span>
            <span>$<%= (summary.deliveryFeeCents/100).toFixed(2) %></span>
          </div>
        <% } %>
        <% if (summary.pointsTotal) { %>
          <div class="row">
            <span>Points subtotal</span>
            <span><%= summary.pointsTotal %> pts</span>
          </div>
        <% } %>
        <div class="row total">
          <span>Total</span>
          <span>$<%= (summary.totalCents/100).toFixed(2) %><% if (summary.pointsTotal) { %> + <%= summary.pointsTotal %> pts<% } %></span>
        </div>
        <button class="cc-btn cc-btn-primary cc-btn-block mt-3" onclick="ppz.checkoutFromCart()">
          Checkout · PayNow
        </button>
        <p class="text-muted mt-3" style="font-size:.85rem;">Payments processed securely via Stripe PayNow.</p>
      </aside>
    </div>
  <% } %>
</div>
<script>
  // Capture delivery shipping address before checkout, otherwise the
  // server falls back to the user's default address.
  window.ppz = window.ppz || {};
  window.ppz._cart = {
    fulfilmentMethod: '<%= summary.fulfilmentMethod || "delivery" %>',
  };
  window.ppz.checkoutFromCart = async function () {
    const form = document.getElementById('shippingForm');
    if (window.ppz._cart.fulfilmentMethod === 'delivery' && form) {
      if (!window.ppz.setShippingAddress(form)) return;
    }
    return window.ppz.checkout();
  };
</script>
<%- include('../partials/foot') %>
