<%- include('partials/head') %>
<%- include('partials/nav', { user: null }) %>
<div class="container">
  <div class="cc-card-form" style="max-width:480px;">
    <h2>Create account</h2>
    <form id="regForm">
      <div class="mb-3"><label>Name</label><input class="form-control" name="name" required></div>
      <div class="mb-3"><label>Email</label><input type="email" class="form-control" name="email" required></div>
      <div class="mb-3">
        <label>Password</label>
        <input type="password" class="form-control" name="password" minlength="8" required>
        <small class="text-muted">At least 8 characters with upper, lower, and a digit or symbol.</small>
      </div>
      <div class="mb-3">
        <label>Confirm password</label>
        <input type="password" class="form-control" name="confirmPassword" minlength="8" required>
      </div>
      <div class="mb-3"><label>Contact</label><input class="form-control" name="contact" placeholder="e.g. 91234567"></div>
      <div class="mb-3"><label>Address line</label><input class="form-control" name="line1" placeholder="Street, unit number" required></div>
      <div class="row">
        <div class="col-md-6 mb-3"><label>Postal code</label><input class="form-control" name="postalCode" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" placeholder="6 digits" required></div>
        <div class="col-md-6 mb-3"><label>Country</label>
          <select class="form-select" name="country" disabled>
            <option value="SG" selected>Singapore</option>
          </select>
        </div>
      </div>
      <button class="cc-btn cc-btn-primary cc-btn-block">Create account</button>
      <div id="err" class="text-danger mt-3"></div>
    </form>
    <p class="mt-3 text-center text-muted" style="font-size:.9rem;">
      Already have an account? <a href="/login">Sign in</a>
    </p>
  </div>
</div>
<script>
const PWD_RE = /^(?=.*[a-z])(?=.*[A-Z])(?=.*[\d\W])[\s\S]{8,}$/;

document.getElementById('regForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const errEl = document.getElementById('err');
  errEl.innerText = '';
  const fd = new FormData(e.target);
  const password = fd.get('password');
  const confirm = fd.get('confirmPassword');
  if (!PWD_RE.test(password)) {
    errEl.innerText = 'Password must be at least 8 characters with upper, lower, and a digit or symbol.';
    return;
  }
  if (password !== confirm) {
    errEl.innerText = 'Passwords do not match.';
    return;
  }
  const body = {
    name: fd.get('name'),
    email: fd.get('email'),
    password,
    contact: fd.get('contact') || undefined,
    address: {
      line1: fd.get('line1'),
      postalCode: fd.get('postalCode'),
      country: 'SG',
    },
  };
  const res = await fetch('/api/auth/register', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body),
  });
  if (res.ok) location.href = '/';
  else errEl.innerText = (await res.json()).message || 'Registration failed';
});
</script>
<%- include('partials/foot') %>
