<%
// activePath is set by the page including this partial.
const items = [
  { href: '/admin',            label: 'Dashboard',   icon: '◰' },
  { href: '/admin/users',      label: 'Users',       icon: '◉' },
  { href: '/admin/products',   label: 'Products',    icon: '▣' },
  { href: '/admin/products/disabled', label: 'Disabled products', icon: '⌽' },
  { href: '/admin/categories', label: 'Categories',  icon: '◇' },
  { href: '/admin/orders',     label: 'Orders',      icon: '⌘' },
  { href: '/admin/sales',      label: 'Sales report', icon: '⌗' },
  { href: '/admin/collection', label: 'Manage Collection', icon: '⊞' },
  { href: '/admin/pages',      label: 'Page Edit',   icon: '✎' },
  { href: '/admin/import',     label: 'Bulk import', icon: '↥' },
  { href: '/admin/settings',   label: 'Settings',    icon: '⚙' },
];
%>
<aside class="admin-sidebar">
  <div class="group-label">Admin</div>
  <% items.forEach(it => { %>
    <a href="<%= it.href %>" class="<%= activePath === it.href ? 'is-active' : '' %>">
      <span class="icon"><%= it.icon %></span>
      <span><%= it.label %></span>
    </a>
  <% }); %>
  <div class="group-label">Storefront</div>
  <a href="/"><span class="icon">↗</span><span>View shop</span></a>
</aside>
