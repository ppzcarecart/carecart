<%
// Build a deterministic gradient + initial for the avatar so the same
// user always renders the same colour across the app.
const avatarPalettes = [
  ['#0f766e','#14b8a6'], ['#0369a1','#0ea5e9'], ['#7c3aed','#a78bfa'],
  ['#be185d','#ec4899'], ['#b45309','#f59e0b'], ['#15803d','#22c55e'],
];
let avatarHash = 0;
const avatarKey = (user && user.name) || '';
for (let i = 0; i < avatarKey.length; i++) avatarHash = (avatarHash * 31 + avatarKey.charCodeAt(i)) >>> 0;
const avatarPalette = avatarPalettes[avatarHash % avatarPalettes.length];
const avatarInitial = (avatarKey || '?').trim().charAt(0).toUpperCase();
%>
<nav class="cc-nav">
  <div class="container d-flex align-items-center justify-content-between">
    <a href="/" class="cc-brand">
      <span class="cc-brand-mark">c</span>
      <span>carecart</span>
    </a>
    <div class="cc-links">
      <a href="/" class="cc-pill">Shop</a>
      <% if (user) { %>
        <a href="/cart" class="cc-pill">Cart</a>
        <% if (user.role === 'admin' || user.role === 'manager') { %>
          <a href="/admin" class="cc-pill cc-pill-outline">Admin</a>
        <% } %>
        <% if (user.role === 'vendor') { %>
          <a href="/vendor" class="cc-pill cc-pill-outline">Vendor</a>
        <% } %>
        <% if (user.ppzId && user.ppzCurrency != null) { %>
          <a href="/profile" class="cc-points-pill" title="View profile">
            <span class="cc-points-icon">★</span>
            <span class="cc-points-value"><%= Number(user.ppzCurrency).toLocaleString() %></span>
            <span class="cc-points-label">pts</span>
          </a>
        <% } %>
        <a href="/profile" class="cc-avatar" title="<%= user.name %> · View profile"
           style="background: linear-gradient(135deg, <%= avatarPalette[0] %> 0%, <%= avatarPalette[1] %> 100%);">
          <span><%= avatarInitial %></span>
        </a>
      <% } else { %>
        <a href="/login" class="cc-pill cc-pill-primary">Sign in</a>
      <% } %>
    </div>
  </div>
</nav>
<script src="/static/app.js"></script>
