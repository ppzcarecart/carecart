<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container">
    <a class="navbar-brand" href="/">carecart</a>
    <div class="d-flex">
      <a href="/" class="btn btn-outline-light btn-sm me-2">Shop</a>
      <% if (user) { %>
        <a href="/cart" class="btn btn-outline-light btn-sm me-2">Cart</a>
        <a href="/orders" class="btn btn-outline-light btn-sm me-2">Orders</a>
        <% if (user.role === 'admin' || user.role === 'manager') { %>
          <a href="/admin" class="btn btn-warning btn-sm me-2">Admin</a>
        <% } %>
        <% if (user.role === 'vendor') { %>
          <a href="/vendor" class="btn btn-info btn-sm me-2">Vendor</a>
        <% } %>
        <span class="navbar-text text-light me-2"><%= user.name %> (<%= user.role %>)</span>
        <button class="btn btn-outline-light btn-sm" onclick="ppz.logout()">Logout</button>
      <% } else { %>
        <a href="/login" class="btn btn-outline-light btn-sm me-2">Login</a>
        <a href="/register" class="btn btn-light btn-sm">Sign up</a>
      <% } %>
    </div>
  </div>
</nav>
<script src="/static/app.js"></script>
