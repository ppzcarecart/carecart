<%
const items = [
  { href: '/vendor',           label: 'Dashboard',         icon: '◰' },
  { href: '/vendor/products',  label: 'My products',       icon: '▣' },
  { href: '/vendor/collection', label: 'Manage Collection', icon: '⊞' },
  { href: '/vendor/settings',  label: 'Settings',          icon: '⚙' },
];
%>
<aside class="admin-sidebar">
  <div class="group-label">Vendor</div>
  <% items.forEach(it => { %>
    <a href="<%= it.href %>" class="<%= activePath === it.href ? 'is-active' : '' %>">
      <span class="icon"><%= it.icon %></span>
      <span><%= it.label %></span>
    </a>
  <% }); %>
  <div class="group-label">Storefront</div>
  <a href="/"><span class="icon">↗</span><span>View shop</span></a>
</aside>
