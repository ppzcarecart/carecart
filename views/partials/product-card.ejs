<%
const NEW_WINDOW_MS = 7 * 24 * 60 * 60 * 1000;
const isNew = product.createdAt && (Date.now() - new Date(product.createdAt).getTime() < NEW_WINDOW_MS);
// Caller should pass isPpzMember; default to false for safety.
const ppzMember = (typeof isPpzMember !== 'undefined') ? isPpzMember : false;
const showPpzPrice = ppzMember && product.ppzPriceCents != null;
const cashCents = showPpzPrice ? product.ppzPriceCents : product.priceCents;
const showStrike = showPpzPrice && product.ppzPriceCents < product.priceCents;
// effectivePointsPrice + effectiveRedeem* are decorated by
// ProductsService.enrichForView when the viewer is a member; the
// redeem fields reflect the hybrid offset (points → cents discount,
// capped at product price; remainder paid in cash).
const ptsValue = (product.effectivePointsPrice != null) ? product.effectivePointsPrice : (ppzMember ? product.pointsPrice : null);
const showPoints = ppzMember && ptsValue;
const redeemPoints = product.effectiveRedeemPoints != null ? product.effectiveRedeemPoints : ptsValue;
const redeemCashCents = product.effectiveRedeemCashCents != null ? product.effectiveRedeemCashCents : 0;
// $0 cash + points set = redeem-only listing; suppress the $0.00 line
// so the card reads as a points redemption instead of a freebie.
const isPointsOnly = showPoints && cashCents === 0 && ptsValue > 0;
%>
<a href="/p/<%= product.slug %>" class="cc-card text-decoration-none text-reset">
  <div class="cc-thumb">
    <%- include('product-thumb', { product }) %>
    <div class="cc-thumb-badges">
      <% if (product.featured) { %><span class="cc-badge cc-badge-featured">Featured</span><% } %>
      <% if (isNew) { %><span class="cc-badge cc-badge-new">New</span><% } %>
      <% if (showPpzPrice) { %><span class="cc-badge cc-badge-ppz">PPZ</span><% } %>
    </div>
  </div>
  <div class="cc-body">
    <span class="cc-vendor"><%= product.vendor && (product.vendor.vendorStoreName || product.vendor.name) || 'Vendor' %></span>
    <h3 class="cc-name"><%= product.name %></h3>
    <div class="cc-price">
      <% if (!isPointsOnly) { %>
        <span class="amount">$<%= (cashCents / 100).toFixed(2) %></span>
        <% if (showStrike) { %>
          <span class="amount-strike">$<%= (product.priceCents / 100).toFixed(2) %></span>
        <% } %>
      <% } %>
      <% if (showPoints) { %>
        <span class="points">
          <% if (!isPointsOnly) { %>or <% } %><%= redeemPoints %> pts<% if (redeemCashCents > 0) { %> at $<%= (redeemCashCents/100).toFixed(2) %><% } %>
        </span>
      <% } %>
    </div>
  </div>
</a>
