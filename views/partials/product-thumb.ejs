<%
// Renders the thumbnail block for a product card / detail.
// If the image URL fails to load, ppz.imgFallback (in /static/app.js) swaps
// the <img> for a gradient placeholder using the product's first letter.
const palettes = [
  ['#0f766e', '#14b8a6'],
  ['#0369a1', '#0ea5e9'],
  ['#7c3aed', '#a78bfa'],
  ['#be185d', '#ec4899'],
  ['#b45309', '#f59e0b'],
  ['#15803d', '#22c55e'],
  ['#475569', '#94a3b8'],
];
let hash = 0;
const key = (product.slug || product.name || 'x');
for (let i = 0; i < key.length; i++) hash = (hash * 31 + key.charCodeAt(i)) >>> 0;
const palette = palettes[hash % palettes.length];
const initial = (product.name || 'x').trim().charAt(0).toUpperCase();
const bg = `linear-gradient(135deg, ${palette[0]} 0%, ${palette[1]} 100%)`;
%>
<% if (product.images && product.images[0]) { %>
  <img src="<%= product.images[0].url %>"
       alt="<%= product.name %>"
       loading="lazy"
       data-fallback-bg="<%= bg %>"
       data-fallback-initial="<%= initial %>"
       onerror="ppz.imgFallback(this)">
<% } else { %>
  <div class="cc-placeholder" style="background: <%= bg %>; height: 100%; width: 100%;">
    <span><%= initial %></span>
  </div>
<% } %>
