<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container admin-shell">
  <div class="admin-layout">
    <%- include('../partials/admin-sidebar', { activePath }) %>
    <main class="admin-main">

      <div class="admin-page-header">
        <div>
          <h1>Bulk import customers</h1>
          <p class="lede">Upload a CSV with columns <code>Name, Email, Address, Contact, Password</code>. Existing emails are skipped.</p>
        </div>
      </div>

      <div class="admin-panel" style="max-width: 720px;">
        <div class="panel-body padded">
          <form id="bulk" enctype="multipart/form-data">
            <label>Choose file</label>
            <input type="file" name="file" accept=".csv,text/csv" class="form-control mb-3" required>
            <button class="cc-btn cc-btn-primary">Upload &amp; import</button>
          </form>
        </div>
      </div>

      <div class="admin-panel" style="max-width: 720px;" id="resultPanel" hidden>
        <div class="panel-head"><h3>Import results</h3></div>
        <div class="panel-body padded">
          <pre id="result" style="margin:0; font-size:.85rem;"></pre>
        </div>
      </div>

    </main>
  </div>
</div>
<script>
document.getElementById('bulk').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const res = await fetch('/api/users/bulk-import', { method: 'POST', body: fd });
  document.getElementById('resultPanel').hidden = false;
  document.getElementById('result').innerText = JSON.stringify(await res.json(), null, 2);
});
</script>
<%- include('../partials/foot') %>
