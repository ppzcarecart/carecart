<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container admin-shell">
  <div class="admin-layout">
    <%- include('../partials/admin-sidebar', { activePath }) %>
    <main class="admin-main">

      <div class="admin-page-header">
        <div>
          <h1>Users</h1>
          <p class="lede">Vendors, customers, managers, and admins.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
          <button class="cc-btn cc-btn-outline" id="syncAllBtn" onclick="ppz.syncAllPpzUsers(this)" title="Pull latest balance &amp; lifetime from the partner app for every PPZ-linked user">
            Sync all PPZ users
          </button>
          <a href="/admin/import" class="cc-btn cc-btn-outline">Bulk import</a>
          <button class="cc-btn cc-btn-primary" data-bs-toggle="modal" data-bs-target="#newUser">+ New user</button>
        </div>
      </div>

      <!-- Search + filter. GET form so the URL reflects the active
           filter (shareable, refresh-friendly). Empty fields are
           dropped server-side. -->
      <form method="GET" action="/admin/users" class="admin-panel" style="margin-bottom: 14px;">
        <div class="panel-body padded">
          <div class="row g-2 align-items-end">
            <div class="col-md-5">
              <label class="text-muted" style="font-size:.78rem;">Search</label>
              <input class="form-control" type="search" name="q"
                value="<%= filters.q %>"
                placeholder="Name, email, contact, or PPZ ID"
                autocomplete="off">
            </div>
            <div class="col-md-3">
              <label class="text-muted" style="font-size:.78rem;">Role</label>
              <select class="form-select" name="role">
                <option value="" <%= filters.role === '' ? 'selected' : '' %>>Any role</option>
                <% ['admin','manager','vendor','scanner','customer'].forEach(function(r) { %>
                  <% if (!(user.role === 'manager' && r === 'admin')) { %>
                    <option value="<%= r %>" <%= filters.role === r ? 'selected' : '' %>><%= r %></option>
                  <% } %>
                <% }); %>
              </select>
            </div>
            <div class="col-md-3">
              <label class="text-muted" style="font-size:.78rem;">PPZ role</label>
              <select class="form-select" name="ppzRole">
                <option value="" <%= filters.ppzRole === '' ? 'selected' : '' %>>Any PPZ role</option>
                <% ppzRoles.forEach(function(r) { %>
                  <option value="<%= r %>" <%= filters.ppzRole === r ? 'selected' : '' %>><%= ppzRoleLabels[r] %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-1 d-grid">
              <button class="cc-btn cc-btn-primary" type="submit" style="padding:8px 14px;">Filter</button>
            </div>
          </div>
          <% if (filters.q || filters.role || filters.ppzRole) { %>
            <div class="mt-2">
              <a href="/admin/users" class="text-muted" style="font-size:.85rem;">Clear filters</a>
              <span class="text-muted" style="font-size:.85rem;">· <%= users.length %> match<%= users.length === 1 ? '' : 'es' %></span>
            </div>
          <% } %>
        </div>
      </form>

      <div class="admin-panel">
        <div class="panel-body">
          <% if (!users.length) { %>
            <div class="cc-empty" style="margin: 0; border: none; border-radius: 0;">
              <% if (filters.q || filters.role || filters.ppzRole) { %>
                No users match the current filters. <a href="/admin/users">Clear filters</a>.
              <% } else { %>
                No users yet.
              <% } %>
            </div>
          <% } else { %>
            <table class="admin-table" data-mobile="cards">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Email / Contact</th>
                  <th>Role</th>
                  <th>PPZ Role</th>
                  <th>PPZ ID</th>
                  <th class="num">Points</th>
                  <th class="num">Lifetime</th>
                  <th class="num">Team</th>
                  <th>Status</th>
                  <th class="actions">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach(u => { %>
                  <tr>
                    <td>
                      <% if (user.role === 'admin' || user.role === 'manager') { %>
                        <strong><a href="/admin/users/<%= u.id %>" class="text-reset"><%= u.name %></a></strong>
                      <% } else { %>
                        <strong><%= u.name %></strong>
                      <% } %>
                      <% if (u.vendorStoreName) { %><div class="text-muted" style="font-size:.82rem"><%= u.vendorStoreName %></div><% } %>
                    </td>
                    <td data-label="Email">
                      <%= u.email %>
                      <% if (u.contact) { %><div class="text-muted" style="font-size:.82rem"><%= u.contact %></div><% } %>
                    </td>
                    <td data-label="Role">
                      <%
                      // Manager can never assign admin; everything else is allowed.
                      const allowedRoles = user.role === 'admin'
                        ? ['admin','manager','vendor','scanner','customer']
                        : ['manager','vendor','scanner','customer'];
                      %>
                      <select data-current-role="<%= u.role %>"
                        onchange="ppz.setUserRole('<%= u.id %>', this.value, this)">
                        <% allowedRoles.forEach(r => { %>
                          <option value="<%= r %>" <%= u.role === r ? 'selected' : '' %>><%= r %></option>
                        <% }); %>
                      </select>
                      <% if (u.roleExpiresAt) { %>
                        <div class="text-muted" style="font-size:.78rem; margin-top:2px;">
                          expires <%= fmtSg(u.roleExpiresAt) %>
                          <% if (u.roleBeforeOverride) { %>
                            → <%= u.roleBeforeOverride %>
                          <% } %>
                        </div>
                      <% } else if (u.role === 'scanner') { %>
                        <div class="text-muted" style="font-size:.78rem; margin-top:2px;">
                          permanent (no expiry)
                        </div>
                      <% } %>
                    </td>
                    <td data-label="PPZ Role">
                      <% if (u.ppzId) { %>
                        <%= u.ppzRole && ppzRoleLabels[u.ppzRole] ? ppzRoleLabels[u.ppzRole] : 'New Member' %>
                      <% } else { %>
                        <span class="text-muted">–</span>
                      <% } %>
                    </td>
                    <td data-label="PPZ ID"><%= u.ppzId || '–' %></td>
                    <td class="num" data-label="Points"><%= u.ppzId ? (u.ppzCurrency ?? 0).toLocaleString() : '–' %></td>
                    <td class="num" data-label="Lifetime"><%= u.ppzId ? (u.lifetimePpzCurrency ?? 0).toLocaleString() : '–' %></td>
                    <td class="num" data-label="Team"><%= u.team ?? '–' %></td>
                    <td data-label="Status"><span class="tag <%= u.active ? 'tag-active' : 'tag-inactive' %>"><%= u.active ? 'active' : 'disabled' %></span></td>
                    <td class="actions">
                      <button class="cc-btn cc-btn-ghost" style="padding:6px 10px; font-size:.85rem;"
                        onclick="ppz.toggleUser('<%= u.id %>', <%= !u.active %>)"><%= u.active ? 'Disable' : 'Enable' %></button>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>

    </main>
  </div>
</div>

<div class="modal fade" id="newUser" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <form id="newUserForm">
    <div class="modal-header"><h5>New user</h5></div>
    <div class="modal-body">
      <div class="mb-3"><label>Name</label><input class="form-control" name="name" required></div>
      <div class="mb-3"><label>Email</label><input type="email" class="form-control" name="email" required></div>
      <div class="mb-3"><label>Password</label><input class="form-control" name="password" minlength="6" required></div>
      <div class="mb-3"><label>Contact</label><input class="form-control" name="contact"></div>
      <div class="mb-3"><label>Address</label><input class="form-control" name="address"></div>
      <div class="mb-3"><label>Role</label><select class="form-select" name="role">
        <option value="customer">Customer</option>
        <option value="vendor">Vendor</option>
        <option value="manager">Manager</option>
        <% if (user.role === 'admin') { %>
          <option value="admin">Admin</option>
        <% } %>
      </select></div>
      <div class="mb-3"><label>Vendor store name (vendors only)</label><input class="form-control" name="vendorStoreName"></div>
      <div class="row">
        <div class="col-md-6 mb-3"><label>PPZ ID (optional)</label><input class="form-control" name="ppzId"></div>
        <div class="col-md-6 mb-3"><label>Team (optional)</label><input class="form-control" type="number" name="team"></div>
      </div>
      <div class="row">
        <div class="col-md-6 mb-3"><label>PPZ currency (optional)</label><input class="form-control" type="number" min="0" name="ppzCurrency"></div>
        <div class="col-md-6 mb-3"><label>Lifetime PPZ currency (optional)</label><input class="form-control" type="number" min="0" name="lifetimePpzCurrency"></div>
      </div>
    </div>
    <div class="modal-footer"><button class="cc-btn cc-btn-primary">Create user</button></div>
  </form>
</div></div></div>

<script>
document.getElementById('newUserForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const body = Object.fromEntries(fd.entries());
  // Coerce numeric fields so the DTO validators accept them.
  for (const k of ['ppzCurrency', 'lifetimePpzCurrency', 'team']) {
    if (body[k] === '' || body[k] == null) delete body[k];
    else body[k] = parseInt(body[k], 10);
  }
  for (const k of ['ppzId', 'vendorStoreName', 'contact', 'address']) {
    if (body[k] === '') delete body[k];
  }
  const res = await fetch('/api/users', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
  if (res.ok) location.reload();
  else alert((await res.json()).message);
});
</script>
<%- include('../partials/foot') %>
