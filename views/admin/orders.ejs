<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container py-4">
  <h1>Orders</h1>
  <table class="table">
    <thead><tr><th>Number</th><th>Customer</th><th>Status</th><th>Total</th><th>Points</th><th>Created</th><th></th></tr></thead>
    <tbody>
    <% orders.forEach(o => { %>
      <tr>
        <td><%= o.number %></td>
        <td><%= o.customer ? o.customer.email : '-' %></td>
        <td>
          <select onchange="ppz.setOrderStatus('<%= o.id %>', this.value)">
            <% ['pending','awaiting_payment','paid','fulfilled','cancelled','refunded'].forEach(s => { %>
              <option value="<%= s %>" <%= o.status === s ? 'selected' : '' %>><%= s %></option>
            <% }); %>
          </select>
        </td>
        <td>$<%= (o.totalCents/100).toFixed(2) %></td>
        <td><%= o.pointsTotal %></td>
        <td><%= new Date(o.createdAt).toLocaleString() %></td>
        <td></td>
      </tr>
    <% }); %>
    </tbody>
  </table>
</div>
<%- include('../partials/foot') %>
