<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container admin-shell">
  <div class="admin-layout">
    <%- include('../partials/admin-sidebar', { activePath }) %>
    <main class="admin-main">

      <div class="admin-page-header">
        <div>
          <h1>Orders</h1>
          <p class="lede">All orders across the marketplace. Update status to advance or cancel an order.</p>
        </div>
      </div>

      <div class="admin-panel">
        <div class="panel-body">
          <% if (!orders.length) { %>
            <div class="cc-empty" style="margin:0; border:none; border-radius:0;">No orders yet.</div>
          <% } else { %>
            <table class="admin-table" data-mobile="cards">
              <thead>
                <tr>
                  <th>Number</th>
                  <th>Customer</th>
                  <th>CType</th>
                  <th>Status</th>
                  <th class="num">Total</th>
                  <th class="num">Points</th>
                  <th>Created</th>
                </tr>
              </thead>
              <tbody>
              <% orders.forEach(o => { %>
                <%
                const ctype = o.customer ? (o.customer.ppzId ? 'PPZ' : 'CC') : 'NA';
                %>
                <tr>
                  <td><strong><a href="/admin/orders/<%= o.id %>" class="text-reset"><%= o.number %></a></strong></td>
                  <td data-label="Customer"><%= o.customer ? o.customer.email : '-' %></td>
                  <td data-label="Type">
                    <% if (ctype === 'NA') { %>
                      <span class="text-muted">—</span>
                    <% } else { %>
                      <span class="ctype-tag ctype-<%= ctype.toLowerCase() %>"><%= ctype %></span>
                    <% } %>
                  </td>
                  <td data-label="Status">
                    <select <%= o.status === 'refunded' ? 'disabled' : '' %>
                      onchange="ppz.setOrderStatus('<%= o.id %>', this.value)"
                      title="<%= o.status === 'refunded' ? 'Refunded orders cannot change status' : '' %>">
                      <% ['pending','awaiting_payment','paid','fulfilled','collected','cancelled','refunded'].forEach(s => { %>
                        <option value="<%= s %>" <%= o.status === s ? 'selected' : '' %>><%= s %></option>
                      <% }); %>
                    </select>
                  </td>
                  <td class="num" data-label="Total">$<%= (o.totalCents/100).toFixed(2) %></td>
                  <td class="num" data-label="Points"><%= o.pointsTotal ? Number(o.pointsTotal).toLocaleString() : '–' %></td>
                  <td class="text-muted" data-label="Created"><%= new Date(o.createdAt).toLocaleString() %></td>
                </tr>
              <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>

    </main>
  </div>
</div>
<%- include('../partials/foot') %>
