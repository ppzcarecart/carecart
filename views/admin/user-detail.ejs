<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container admin-shell">
  <div class="admin-layout">
    <%- include('../partials/admin-sidebar', { activePath }) %>
    <main class="admin-main">

      <div class="admin-page-header">
        <div>
          <h1><%= target.name %></h1>
          <p class="lede"><a href="<%= returnTo %>">← Back to users</a></p>
        </div>
        <div class="d-flex gap-2 align-items-center">
          <span class="tag tag-<%= target.role %>"><%= target.role %></span>
          <span class="tag <%= target.active ? 'tag-active' : 'tag-inactive' %>"><%= target.active ? 'active' : 'disabled' %></span>
          <% if (target.ppzId) { %>
            <span class="ctype-tag ctype-ppz">PPZ</span>
          <% } else if (target.role === 'customer') { %>
            <span class="ctype-tag ctype-cc">CC</span>
          <% } %>
        </div>
      </div>

      <div class="profile-grid">

        <div class="admin-panel">
          <div class="panel-head"><h3>Account</h3></div>
          <div class="panel-body padded">
            <dl class="profile-dl">
              <dt>Name</dt><dd><%= target.name %></dd>
              <dt>Email</dt><dd><%= target.email %></dd>
              <dt>Contact</dt><dd><%= target.contact || '—' %></dd>
              <dt>Role</dt><dd><%= target.role %></dd>
              <dt>Status</dt><dd><%= target.active ? 'Active' : 'Disabled' %></dd>
              <dt>Password set</dt><dd><%= target.hasSetPassword ? 'Yes' : 'No (handoff)' %></dd>
              <dt>Created</dt><dd><%= new Date(target.createdAt).toLocaleString() %></dd>
              <dt>Updated</dt><dd><%= new Date(target.updatedAt).toLocaleString() %></dd>
            </dl>
          </div>
        </div>

        <div class="admin-panel">
          <div class="panel-head"><h3>Address</h3></div>
          <div class="panel-body padded">
            <% if (target.addresses && target.addresses.length) { %>
              <% target.addresses.forEach(a => { %>
                <div class="profile-address" style="margin-bottom:10px;">
                  <% if (a.isDefault) { %><span class="tag tag-active mb-2">Default</span><% } %>
                  <div><%= a.line1 %></div>
                  <% if (a.line2) { %><div><%= a.line2 %></div><% } %>
                  <% const region = [a.city, a.state, a.postalCode].filter(Boolean).join(' '); %>
                  <% if (region) { %><div class="text-muted"><%= region %></div><% } %>
                  <% if (a.country) { %><div class="text-muted"><%= a.country %></div><% } %>
                </div>
              <% }); %>
            <% } else { %>
              <p class="text-muted mb-0">No address on file.</p>
            <% } %>
          </div>
        </div>

        <% if (target.ppzId) { %>
          <div class="admin-panel profile-ppz">
            <div class="panel-head">
              <h3>PPZ Wallet</h3>
              <div class="d-flex gap-2">
                <button class="cc-btn cc-btn-outline" style="padding:6px 14px; font-size:.85rem;"
                  onclick="ppz.syncUserFromPpz(this, '<%= target.id %>')"
                  title="Pull latest balance/lifetime from the partner app">
                  Sync now
                </button>
                <% if (user.role === 'admin') { %>
                  <button class="cc-btn cc-btn-primary" style="padding:6px 14px; font-size:.85rem;"
                    data-bs-toggle="modal" data-bs-target="#addPointsModal">
                    + Add points
                  </button>
                <% } %>
              </div>
            </div>
            <div class="panel-body padded">
              <div class="ppz-stats">
                  <div class="ppz-stat">
                    <div class="ppz-stat-label">PPZ ID</div>
                    <div class="ppz-stat-value"><%= target.ppzId %></div>
                  </div>
                  <div class="ppz-stat ppz-stat-primary">
                    <div class="ppz-stat-label">Current balance</div>
                    <div class="ppz-stat-value">
                      <span id="td-ppzCurrency"><%= Number(target.ppzCurrency).toLocaleString() %></span>
                      <span class="ppz-stat-unit">pts</span>
                    </div>
                  </div>
                  <div class="ppz-stat">
                    <div class="ppz-stat-label">Lifetime earned</div>
                    <div class="ppz-stat-value">
                      <span id="td-lifetime"><%= Number(target.lifetimePpzCurrency).toLocaleString() %></span>
                      <span class="ppz-stat-unit">pts</span>
                    </div>
                  </div>
                <div class="ppz-stat">
                  <div class="ppz-stat-label">Team</div>
                  <div class="ppz-stat-value"><%= target.team ?? '—' %></div>
                </div>
              </div>
            </div>
          </div>
        <% } %>

        <% if (target.role === 'vendor') { %>
          <div class="admin-panel">
            <div class="panel-head"><h3>Vendor profile</h3></div>
            <div class="panel-body padded">
              <dl class="profile-dl">
                <dt>Store name</dt><dd><%= target.vendorStoreName || '—' %></dd>
                <dt>Bio</dt><dd><%= target.vendorBio || '—' %></dd>
                <dt>Own collection</dt><dd><%= target.useOwnCollectionLocation ? 'Yes' : 'No (uses admin)' %></dd>
                <dt>Own delivery fee</dt>
                <dd><%= target.useOwnDeliveryFee && target.vendorDeliveryFeeCents != null
                       ? '$' + (target.vendorDeliveryFeeCents/100).toFixed(2)
                       : 'No (uses admin)' %></dd>
              </dl>
            </div>
          </div>
        <% } %>

      </div>

    </main>
  </div>
</div>

<% if (user.role === 'admin' && target.ppzId) { %>
  <div class="modal fade" id="addPointsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <form id="addPointsForm" onsubmit="event.preventDefault(); ppz.addPointsToUser(this, '<%= target.id %>')">
          <div class="modal-header">
            <h5>Add PPZ points · <%= target.name %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p class="text-muted" style="font-size:.9rem;">
              Calls the partner app to credit the customer's PPZ account
              with <em>operation: add</em>. The reason below appears in
              their PPZ transaction history.
            </p>
            <div class="row">
              <div class="col-md-5 mb-3">
                <label>Amount (points) <span class="text-danger">*</span></label>
                <input type="number" min="1" step="1" class="form-control" name="amount" required placeholder="500">
              </div>
              <div class="col-md-7 mb-3">
                <label>PPZ ID</label>
                <input class="form-control" value="<%= target.ppzId %>" disabled>
              </div>
            </div>
            <div class="mb-2">
              <label>Reason <span class="text-danger">*</span></label>
              <textarea class="form-control" name="reason" rows="3" maxlength="500" required
                placeholder="e.g. Goodwill credit · campaign #2026Q2"></textarea>
            </div>
            <div id="addPointsError" class="text-danger small" style="min-height:1.2em;"></div>
          </div>
          <div class="modal-footer">
            <button type="button" class="cc-btn cc-btn-ghost" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="cc-btn cc-btn-primary">Confirm add</button>
          </div>
        </form>
      </div>
    </div>
  </div>
<% } %>
<%- include('../partials/foot') %>
