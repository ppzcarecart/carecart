<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container admin-shell">
  <div class="admin-layout">
    <%- include('../partials/admin-sidebar', { activePath }) %>
    <main class="admin-main">

      <div class="admin-page-header">
        <div>
          <h1>Products</h1>
          <p class="lede">Toggle <strong>Featured</strong> to highlight a product on the storefront — up to 8 at a time.</p>
        </div>
        <button class="cc-btn cc-btn-primary" data-bs-toggle="modal" data-bs-target="#newProduct">+ New product</button>
      </div>

      <div class="admin-panel">
        <div class="panel-body">
          <% if (!products.length) { %>
            <div class="cc-empty" style="margin:0; border:none; border-radius:0;">No products yet.</div>
          <% } else { %>
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Product</th>
                  <th>Vendor</th>
                  <th class="num">Price</th>
                  <th class="num">Points</th>
                  <th class="num">Stock</th>
                  <th>Active</th>
                  <th>Featured</th>
                  <th class="actions">Actions</th>
                </tr>
              </thead>
              <tbody>
              <% products.forEach(p => { %>
                <tr>
                  <td>
                    <div class="row-thumb">
                      <div class="thumb">
                        <%- include('../partials/product-thumb', { product: p }) %>
                      </div>
                      <div class="meta">
                        <strong><a href="/p/<%= p.slug %>" class="text-reset"><%= p.name %></a></strong>
                        <% if (p.category) { %><div class="sub"><%= p.category.name %></div><% } %>
                      </div>
                    </div>
                  </td>
                  <td><%= p.vendor ? (p.vendor.vendorStoreName || p.vendor.name) : '-' %></td>
                  <td class="num">$<%= (p.priceCents/100).toFixed(2) %></td>
                  <td class="num"><%= p.pointsPrice ?? '–' %></td>
                  <td class="num"><%= p.stock %></td>
                  <td><span class="tag <%= p.active ? 'tag-active' : 'tag-inactive' %>"><%= p.active ? 'active' : 'inactive' %></span></td>
                  <td>
                    <label class="cc-switch">
                      <input type="checkbox" <%= p.featured ? 'checked' : '' %>
                        onchange="ppz.setFeatured('<%= p.id %>', this.checked, this)">
                      <span class="cc-switch-slider"></span>
                    </label>
                  </td>
                  <td class="actions"><button class="cc-btn cc-btn-ghost" style="padding:6px 10px; font-size:.85rem;" onclick="ppz.deleteProduct('<%= p.id %>')">Delete</button></td>
                </tr>
              <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>

    </main>
  </div>
</div>

<div class="modal fade" id="newProduct" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <form id="newProductForm">
    <div class="modal-header"><h5>New product</h5></div>
    <div class="modal-body">
      <div class="mb-3"><label>Name</label><input class="form-control" name="name" required></div>
      <div class="mb-3"><label>Description</label><textarea class="form-control" name="description"></textarea></div>
      <div class="row">
        <div class="col-md-6 mb-3"><label>Price (cents)</label><input type="number" min="0" class="form-control" name="priceCents" required></div>
        <div class="col-md-6 mb-3"><label>Points price (optional)</label><input type="number" min="0" class="form-control" name="pointsPrice"></div>
      </div>
      <div class="mb-3"><label>Stock</label><input type="number" min="0" class="form-control" name="stock" value="0"></div>
      <div class="mb-3"><label>Vendor</label>
        <select class="form-select" name="vendorId" required>
          <% vendors.forEach(v => { %><option value="<%= v.id %>"><%= v.vendorStoreName || v.name %> (<%= v.email %>)</option><% }); %>
        </select>
      </div>
      <div class="mb-3"><label>Category</label>
        <select class="form-select" name="categoryId"><option value="">— None —</option>
          <% categories.forEach(c => { %><option value="<%= c.id %>"><%= c.name %></option><% }); %>
        </select>
      </div>
      <div class="mb-3"><label>Image URLs (comma-separated)</label><input class="form-control" name="imageUrls" placeholder="https://..."></div>
    </div>
    <div class="modal-footer"><button class="cc-btn cc-btn-primary">Create product</button></div>
  </form>
</div></div></div>

<script>
document.getElementById('newProductForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const body = {
    name: fd.get('name'),
    description: fd.get('description') || undefined,
    priceCents: parseInt(fd.get('priceCents'), 10),
    pointsPrice: fd.get('pointsPrice') ? parseInt(fd.get('pointsPrice'), 10) : undefined,
    stock: parseInt(fd.get('stock') || '0', 10),
    vendorId: fd.get('vendorId') || undefined,
    categoryId: fd.get('categoryId') || undefined,
    imageUrls: fd.get('imageUrls') ? String(fd.get('imageUrls')).split(',').map(s => s.trim()).filter(Boolean) : undefined,
  };
  const res = await fetch('/api/products', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
  if (res.ok) location.reload();
  else alert((await res.json()).message);
});
</script>
<%- include('../partials/foot') %>
