<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container admin-shell">
  <div class="admin-layout">
    <%- include('../partials/admin-sidebar', { activePath }) %>
    <main class="admin-main">

      <div class="admin-page-header">
        <div>
          <h1>Products<% if (typeof featuredOnly !== 'undefined' && featuredOnly) { %> <span class="text-muted" style="font-size:.6em;">· Featured only</span><% } %></h1>
          <p class="lede">
            <% if (typeof featuredOnly !== 'undefined' && featuredOnly) { %>
              Showing only featured products. <a href="/admin/products">Show all</a>.
            <% } else { %>
              Toggle <strong>Featured</strong> to highlight a product on the storefront — up to 8 at a time.
            <% } %>
          </p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
          <a href="/admin/products/disabled"
            class="cc-btn cc-btn-outline"
            style="<%= (typeof disabledCount !== 'undefined' && disabledCount > 0) ? 'color:#b91c1c; border-color:#fca5a5;' : '' %>">
            Disabled products<% if (typeof disabledCount !== 'undefined') { %> (<%= disabledCount %>)<% } %>
          </a>
          <a href="/admin/products/new" class="cc-btn cc-btn-primary">+ New product</a>
        </div>
      </div>

      <div class="admin-panel">
        <div class="panel-body">
          <% if (!products.length) { %>
            <div class="cc-empty" style="margin:0; border:none; border-radius:0;">No products yet.</div>
          <% } else { %>
            <table class="admin-table" data-mobile="cards">
              <thead>
                <tr>
                  <th class="num" title="Lower numbers display first in the storefront">Sort</th>
                  <th>Product</th>
                  <th>Vendor</th>
                  <th class="num">Price</th>
                  <th class="num">Points</th>
                  <th class="num">Stock</th>
                  <th>Active</th>
                  <th>Featured</th>
                  <th class="actions">Actions</th>
                </tr>
              </thead>
              <tbody>
              <% products.forEach(p => { %>
                <tr>
                  <td class="num" data-label="Sort">
                    <input type="number" min="0" step="1"
                      value="<%= p.sortOrder ?? 0 %>"
                      style="width: 70px; padding:4px 6px; text-align:right;"
                      onchange="ppz.setSortOrder('<%= p.id %>', this.value, this)"
                      title="Lower numbers come first">
                  </td>
                  <td>
                    <div class="row-thumb">
                      <div class="thumb">
                        <%- include('../partials/product-thumb', { product: p }) %>
                      </div>
                      <div class="meta">
                        <strong><a href="/p/<%= p.slug %>" class="text-reset"><%= p.name %></a></strong>
                        <% if (p.category) { %><div class="sub"><%= p.category.name %></div><% } %>
                      </div>
                    </div>
                  </td>
                  <td data-label="Vendor"><%= p.vendor ? (p.vendor.vendorStoreName || p.vendor.name) : '-' %></td>
                  <td class="num" data-label="Price">$<%= (p.priceCents/100).toFixed(2) %></td>
                  <td class="num" data-label="Points"><%= p.pointsPrice ?? '–' %></td>
                  <td class="num" data-label="Stock">
                    <% if (p.variants && p.variants.length) { %>
                      <%= p.variants.reduce((s, v) => s + (v.stock || 0), 0) %>
                      <small class="text-muted" style="font-size:.75rem;">(variants)</small>
                    <% } else { %>
                      <%= p.stock %>
                    <% } %>
                  </td>
                  <td data-label="Active">
                    <label class="cc-switch">
                      <input type="checkbox" <%= p.active ? 'checked' : '' %>
                        onchange="ppz.setActive('<%= p.id %>', this.checked, this)">
                      <span class="cc-switch-slider"></span>
                    </label>
                  </td>
                  <td data-label="Featured">
                    <label class="cc-switch">
                      <input type="checkbox" <%= p.featured ? 'checked' : '' %>
                        onchange="ppz.setFeatured('<%= p.id %>', this.checked, this)">
                      <span class="cc-switch-slider"></span>
                    </label>
                  </td>
                  <td class="actions">
                    <a href="/admin/products/<%= p.id %>/edit" class="cc-btn cc-btn-outline" style="padding:6px 14px; font-size:.85rem;">Edit</a>
                    <button class="cc-btn cc-btn-ghost" style="padding:6px 10px; font-size:.85rem;" onclick="ppz.deleteProduct('<%= p.id %>')">Delete</button>
                  </td>
                </tr>
              <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>

    </main>
  </div>
</div>

<%- include('../partials/foot') %>
