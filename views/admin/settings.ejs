<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container admin-shell">
  <div class="admin-layout">
    <%- include('../partials/admin-sidebar', { activePath }) %>
    <main class="admin-main">

      <div class="admin-page-header">
        <div>
          <h1>Settings</h1>
          <p class="lede">Marketplace-wide configuration. Changes take effect immediately.</p>
        </div>
      </div>

      <div class="admin-panel" style="max-width: 720px;">
        <div class="panel-head">
          <h3>Points conversion rate</h3>
          <span class="muted">$1 = N points</span>
        </div>
        <div class="panel-body padded">
          <p class="text-muted" style="font-size:.92rem;">
            How many PPZ points equal one Singapore dollar. Used for any product
            with <strong>Allow points-only redemption</strong> turned on.
            Cents always round up to the next whole dollar before applying
            the rate (so $0.20 still costs <%= settings.pointsPerDollar %> pts).
          </p>
          <form id="rateForm" class="row g-2" onsubmit="event.preventDefault(); ppz.savePointsRate(this)">
            <div class="col-md-5">
              <label>Points per dollar</label>
              <input type="number" min="1" step="1" class="form-control" name="value" value="<%= settings.pointsPerDollar %>" required>
            </div>
            <div class="col-md-7 d-flex align-items-end">
              <button class="cc-btn cc-btn-primary" style="padding:8px 18px;">Save</button>
              <span id="rateStatus" class="ms-3 small"></span>
            </div>
          </form>
        </div>
      </div>

      <div class="admin-panel" style="max-width: 720px;">
        <div class="panel-head">
          <h3>Self-collection point</h3>
          <span class="muted">Default address for collection orders</span>
        </div>
        <div class="panel-body padded">
          <p class="text-muted" style="font-size:.92rem;">
            Vendors who turn on <strong>Use my own location</strong> in their
            settings will use their own address instead — for their products only.
          </p>
          <form id="collectionForm" onsubmit="event.preventDefault(); ppz.saveCollectionPoint(this)">
            <div class="mb-3"><label>Address line</label>
              <input class="form-control" name="collection.line1" value="<%= settings.collection.line1 %>" placeholder="123 Orchard Road #03-01">
            </div>
            <div class="mb-3"><label>Address line 2 (optional)</label>
              <input class="form-control" name="collection.line2" value="<%= settings.collection.line2 %>">
            </div>
            <div class="row">
              <div class="col-md-4 mb-3"><label>Postal code</label>
                <input class="form-control" name="collection.postalCode" value="<%= settings.collection.postalCode %>" inputmode="numeric" maxlength="6">
              </div>
              <div class="col-md-4 mb-3"><label>Contact (optional)</label>
                <input class="form-control" name="collection.contact" value="<%= settings.collection.contact %>" placeholder="91234567">
              </div>
              <div class="col-md-4 mb-3"><label>Opening hours (optional)</label>
                <input class="form-control" name="collection.hours" value="<%= settings.collection.hours %>" placeholder="Mon-Fri 10am-7pm">
              </div>
            </div>
            <button class="cc-btn cc-btn-primary" style="padding:8px 18px;">Save collection point</button>
            <span id="collectionStatus" class="ms-3 small"></span>
          </form>
        </div>
      </div>

      <div class="admin-panel" style="max-width: 720px;">
        <div class="panel-head">
          <h3>Partner integration</h3>
          <span class="muted">Mobile bottom-nav "Home" button</span>
        </div>
        <div class="panel-body padded">
          <p class="text-muted" style="font-size:.92rem;">
            URL the in-app webview navigates to when a customer taps
            <strong>Home</strong> on the mobile bottom nav. The partner
            app's webview delegate intercepts this URL and dismisses
            the webview. Use a custom scheme like
            <code>papazao://close</code> or whatever the partner team's
            deep-link interceptor expects. Leave blank to disable —
            Home will just call <code>history.back()</code>.
          </p>
          <form id="partnerForm" onsubmit="event.preventDefault(); ppz.savePartnerSettings(this)">
            <div class="mb-3" style="max-width: 460px;">
              <label>Close URL (deep link)</label>
              <input class="form-control" name="partner.closeUrl"
                value="<%= settings.partner.closeUrl %>"
                placeholder="papazao://close"
                spellcheck="false" autocapitalize="off">
            </div>
            <button class="cc-btn cc-btn-primary" style="padding:8px 18px;">Save partner settings</button>
            <span id="partnerStatus" class="ms-3 small"></span>
          </form>
        </div>
      </div>

      <div class="admin-panel" style="max-width: 720px;">
        <div class="panel-head">
          <h3>Home page hero</h3>
          <span class="muted">Heading, subheading, CTA, and image tiles</span>
        </div>
        <div class="panel-body padded">
          <p class="text-muted" style="font-size:.92rem;">
            Edit the marketing copy and the three image tiles shown at
            the top of the home page. CTA URL can be a hash anchor on
            the same page (<code>#catalogue</code>) or a full URL.
          </p>
          <form id="heroForm" onsubmit="event.preventDefault(); ppz.saveHero(this)">
            <div class="mb-3" style="max-width: 460px;">
              <label>Eyebrow (small label above heading)</label>
              <input class="form-control" name="home.hero.eyebrow" value="<%= hero.eyebrow %>">
            </div>
            <div class="mb-3">
              <label>Heading</label>
              <input class="form-control" name="home.hero.heading" value="<%= hero.heading %>">
            </div>
            <div class="mb-3">
              <label>Subheading</label>
              <textarea class="form-control" name="home.hero.subheading" rows="3"><%= hero.subheading %></textarea>
            </div>
            <div class="row">
              <div class="col-md-5 mb-3">
                <label>CTA button label</label>
                <input class="form-control" name="home.hero.ctaLabel" value="<%= hero.ctaLabel %>">
              </div>
              <div class="col-md-7 mb-3">
                <label>CTA button URL</label>
                <input class="form-control" name="home.hero.ctaHref" value="<%= hero.ctaHref %>" placeholder="#catalogue or https://…">
              </div>
            </div>

            <hr class="mt-2 mb-3">
            <p class="text-muted" style="font-size:.85rem; margin-bottom:14px;">
              Image tiles. Upload a file or paste a URL. Tile 1 is the
              tall left image; tiles 2 and 3 stack on the right.
            </p>
            <% [1,2,3].forEach(function(n) { %>
              <div class="cc-tile-edit">
                <div class="cc-tile-thumb" data-idx="<%= n %>" style="background-image: url('<%= hero['tile' + n] || '' %>');"></div>
                <div class="flex-grow-1">
                  <label class="text-muted" style="font-size:.78rem;">Tile <%= n %> · image URL</label>
                  <input class="form-control" name="home.hero.tile<%= n %>" data-tile-input="<%= n %>" value="<%= hero['tile' + n] || '' %>" placeholder="https://…">
                </div>
                <div>
                  <input type="file" id="tileFile<%= n %>" accept="image/*" hidden onchange="ppz.uploadHeroTile(<%= n %>, this)">
                  <button type="button" class="cc-btn cc-btn-outline" style="padding:6px 14px; font-size:.85rem;" onclick="document.getElementById('tileFile<%= n %>').click()">Upload</button>
                </div>
              </div>
            <% }); %>

            <button class="cc-btn cc-btn-primary" style="padding:8px 18px;">Save hero</button>
            <span id="heroStatus" class="ms-3 small"></span>
          </form>
        </div>
      </div>

      <div class="admin-panel" style="max-width: 720px;">
        <div class="panel-head">
          <h3>Home page banners</h3>
          <span class="muted">Auto-scrolling carousel below the hero</span>
        </div>
        <div class="panel-body padded">
          <p class="text-muted" style="font-size:.92rem;">
            Up to <strong>5 banners</strong>. Each can link to a URL
            (opens in a new tab). Auto-scrolls every 4.5s, pauses on
            hover, swipes on touch. Toggle the switch to show or hide
            the carousel. Empty slots are skipped.
          </p>
          <form id="bannersForm" onsubmit="event.preventDefault(); ppz.saveBanners(this)">
            <div class="form-check form-switch mb-3">
              <input class="form-check-input" type="checkbox" id="bannersEnabled" name="home.banners.enabled" <%= bannersEnabled ? 'checked' : '' %>>
              <label class="form-check-label" for="bannersEnabled">
                Show banner carousel on home page
              </label>
            </div>

            <% [0,1,2,3,4].forEach(function(i) {
              const b = banners[i] || { imageUrl: '', linkUrl: '' };
            %>
              <div class="cc-banner-edit">
                <div class="cc-banner-edit-thumb" data-idx="<%= i %>" style="background-image: url('<%= b.imageUrl %>');"></div>
                <div class="flex-grow-1">
                  <label class="text-muted" style="font-size:.78rem;">Banner <%= i + 1 %> · image URL</label>
                  <input class="form-control mb-2" name="banner_image_<%= i %>" data-banner-img="<%= i %>" value="<%= b.imageUrl %>" placeholder="https://…">
                  <label class="text-muted" style="font-size:.78rem;">Click-through URL (optional)</label>
                  <input class="form-control" name="banner_link_<%= i %>" value="<%= b.linkUrl %>" placeholder="https://…">
                </div>
                <div class="d-flex flex-column gap-2">
                  <input type="file" id="bannerFile<%= i %>" accept="image/*" hidden onchange="ppz.uploadBannerImage(<%= i %>, this)">
                  <button type="button" class="cc-btn cc-btn-outline" style="padding:6px 14px; font-size:.85rem;" onclick="document.getElementById('bannerFile<%= i %>').click()">Upload</button>
                </div>
              </div>
            <% }); %>

            <button class="cc-btn cc-btn-primary" style="padding:8px 18px;">Save banners</button>
            <span id="bannersStatus" class="ms-3 small"></span>
          </form>
        </div>
      </div>

      <div class="admin-panel" style="max-width: 720px;">
        <div class="panel-head">
          <h3>Delivery</h3>
          <span class="muted"><%= settings.delivery.enabled ? 'Enabled' : 'Disabled' %></span>
        </div>
        <div class="panel-body padded">
          <p class="text-muted" style="font-size:.92rem;">
            When enabled, customers can pick delivery at checkout. The fee
            below is charged per item line unless the item or vendor sets
            their own.
          </p>
          <form id="deliveryForm" onsubmit="event.preventDefault(); ppz.saveDeliverySettings(this)">
            <div class="form-check mb-3">
              <input class="form-check-input" type="checkbox" id="deliveryEnabled" name="delivery.enabled" <%= settings.delivery.enabled ? 'checked' : '' %>>
              <label class="form-check-label" for="deliveryEnabled">
                Allow delivery at checkout
              </label>
            </div>
            <div class="mb-3" style="max-width:280px;">
              <label>Default delivery fee (SGD)</label>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <input type="number" step="0.01" min="0" class="form-control" name="delivery.fee" value="<%= (settings.delivery.feeCents/100).toFixed(2) %>">
              </div>
            </div>
            <button class="cc-btn cc-btn-primary" style="padding:8px 18px;">Save delivery settings</button>
            <span id="deliveryStatus" class="ms-3 small"></span>
          </form>
        </div>
      </div>

    </main>
  </div>
</div>
<%- include('../partials/foot') %>
