<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<%
const isVendor = user.role === 'vendor';
const sidebar = isVendor ? '../partials/vendor-sidebar' : '../partials/admin-sidebar';
const baseHref = activePath; // /admin/collection or /vendor/collection
const tabs = [
  { k: 'ready',       label: 'Ready for collection' },
  { k: 'uncollected', label: 'Uncollected' },
  { k: 'logs',        label: 'Logs' },
];
function ageInDays(ts) {
  if (!ts) return 0;
  return Math.floor((Date.now() - new Date(ts).getTime()) / (24 * 60 * 60 * 1000));
}
%>
<div class="container admin-shell">
  <div class="admin-layout">
    <%- include(sidebar, { activePath }) %>
    <main class="admin-main">

      <div class="admin-page-header">
        <div>
          <h1>Manage Collection</h1>
        </div>
      </div>

      <div class="admin-panel">
        <div class="panel-head">
          <h3>Scanner</h3>
          <span class="muted" id="scannerStatus">Starting camera…</span>
        </div>
        <div class="panel-body padded">
          <div id="reader" style="max-width: 200px; margin: 0 auto; border-radius: 12px; overflow: hidden; background: #000; min-height: 100px;"></div>

          <div class="cc-scan-search mt-3">
            <svg class="cc-scan-search-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="7"/>
              <line x1="20" y1="20" x2="16.65" y2="16.65"/>
            </svg>
            <input id="manualInput" type="search" autocomplete="off" autocorrect="off" autocapitalize="characters" spellcheck="false" placeholder="Search order number">
          </div>

          <p class="text-muted text-center mt-3 mb-0" style="font-size:.85rem;">
            Scan a customer's collection QR with the camera, then verify
            the order and mark it as collected.<% if (scope === 'vendor') { %>
            You can only scan orders that contain your products.<% } %>
          </p>
        </div>
      </div>

      <div class="cc-scan-modal" id="scanModal" aria-hidden="true">
        <div class="cc-scan-backdrop" onclick="ppz.collection.dismiss()"></div>
        <div class="cc-scan-dialog" id="scanDialog" role="dialog" aria-modal="true">
          <div class="cc-scan-head">
            <h3 id="scanTitle">Scan</h3>
            <button type="button" class="btn-close" aria-label="Close" onclick="ppz.collection.dismiss()"></button>
          </div>
          <div class="cc-scan-body" id="scanBody"></div>
          <div class="cc-scan-actions" id="scanActions"></div>
        </div>
      </div>

      <div class="admin-panel" style="margin-bottom: 14px;">
        <div class="panel-body padded">
          <div class="d-flex flex-wrap gap-2 align-items-center cc-filter-rail" id="collectionTabs">
            <span class="text-muted" style="font-size:.78rem; text-transform:uppercase; letter-spacing:.04em;">Show</span>
            <% tabs.forEach(function(t) { %>
              <a href="<%= baseHref %>?tab=<%= t.k %>"
                class="cc-btn <%= activeTab === t.k ? 'cc-btn-primary' : 'cc-btn-outline' %>"
                style="padding:6px 14px; font-size:.85rem;">
                <%= t.label %>
              </a>
            <% }); %>
          </div>
          <script>
            (function () {
              const active = document.querySelector('#collectionTabs .cc-btn-primary');
              if (active && active.scrollIntoView) {
                active.scrollIntoView({ inline: 'center', block: 'nearest' });
              }
            })();
          </script>
        </div>
      </div>

      <%
      function renderBundleRow(p, options) {
        const ownItems = p._items || [];
        const ownOrders = p._orders || [];
        const itemCount = ownItems.reduce((s, i) => s + (i.quantity || 0), 0);
        const totalCents = ownOrders.reduce((s, o) => s + (o.totalCents || 0), 0);
        const since = p.packedAt || p.createdAt;
        const age = ageInDays(since);
        return { ownItems, ownOrders, itemCount, totalCents, since, age };
      }
      %>
      <% if (activeTab === 'ready') { %>
        <div class="admin-panel">
          <div class="panel-head">
            <h3>Ready for collection</h3>
            <span class="muted">Packed bundles awaiting pickup · within <%= thresholdDays %> day<%= thresholdDays === 1 ? '' : 's' %> · <%= ready.length %> bundle<%= ready.length === 1 ? '' : 's' %></span>
          </div>
          <div class="panel-body">
            <% if (!ready.length) { %>
              <div class="cc-empty" style="margin:0; border:none; border-radius:0;">
                Nothing waiting for pickup. Bundles only show up here
                once admin or the vendor marks them as <strong>packed</strong>.
              </div>
            <% } else { %>
              <table class="admin-table" data-mobile="cards">
                <thead>
                  <tr>
                    <th>Order(s)</th>
                    <th>Customer</th>
                    <th>PPZ ID</th>
                    <th>Contact</th>
                    <th class="num">Items</th>
                    <th class="num">Total</th>
                    <th>Packed</th>
                    <th class="num">Age</th>
                  </tr>
                </thead>
                <tbody>
                  <% ready.forEach(p => { const r = renderBundleRow(p); %>
                    <tr>
                      <td data-label="Order(s)">
                        <% r.ownOrders.forEach((o, idx) => { %>
                          <% const orderHref = (isVendor ? '/vendor/orders/' : '/admin/orders/') + o.id; %>
                          <strong><a href="<%= orderHref %>" class="text-reset"><%= o.number %></a></strong>
                          <% if (idx < r.ownOrders.length - 1) { %><br><% } %>
                        <% }); %>
                      </td>
                      <td data-label="Customer">
                        <% if (p.customer) { %>
                          <strong><%= p.customer.name %></strong>
                          <% if (p.customer.email) { %><div class="text-muted" style="font-size:.82rem;"><%= p.customer.email %></div><% } %>
                        <% } else { %>—<% } %>
                      </td>
                      <td data-label="PPZ ID"><%= p.customer && p.customer.ppzId ? p.customer.ppzId : '–' %></td>
                      <td data-label="Contact"><%= p.customer && p.customer.contact ? p.customer.contact : '–' %></td>
                      <td class="num" data-label="Items"><%= r.itemCount %></td>
                      <td class="num" data-label="Total">$<%= (r.totalCents/100).toFixed(2) %></td>
                      <td data-label="Packed" class="text-muted"><%= fmtSg(p.packedAt || p.createdAt) %></td>
                      <td class="num" data-label="Age"><%= r.age %>d</td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            <% } %>
          </div>
        </div>
      <% } else if (activeTab === 'uncollected') { %>
        <div class="admin-panel">
          <div class="panel-head">
            <h3>Uncollected</h3>
            <span class="muted">Packed <%= thresholdDays %>+ day<%= thresholdDays === 1 ? '' : 's' %> ago, still not picked up · <%= uncollected.length %> bundle<%= uncollected.length === 1 ? '' : 's' %></span>
          </div>
          <div class="panel-body">
            <% if (!uncollected.length) { %>
              <div class="cc-empty" style="margin:0; border:none; border-radius:0;">
                Nothing overdue right now.
              </div>
            <% } else { %>
              <table class="admin-table" data-mobile="cards">
                <thead>
                  <tr>
                    <th>Order(s)</th>
                    <th>Customer</th>
                    <th>PPZ ID</th>
                    <th>Contact</th>
                    <th class="num">Items</th>
                    <th class="num">Total</th>
                    <th>Packed</th>
                    <th class="num">Age</th>
                  </tr>
                </thead>
                <tbody>
                  <% uncollected.forEach(p => { const r = renderBundleRow(p); %>
                    <tr>
                      <td data-label="Order(s)">
                        <% r.ownOrders.forEach((o, idx) => { %>
                          <% const orderHref = (isVendor ? '/vendor/orders/' : '/admin/orders/') + o.id; %>
                          <strong><a href="<%= orderHref %>" class="text-reset"><%= o.number %></a></strong>
                          <% if (idx < r.ownOrders.length - 1) { %><br><% } %>
                        <% }); %>
                      </td>
                      <td data-label="Customer">
                        <% if (p.customer) { %>
                          <strong><%= p.customer.name %></strong>
                          <% if (p.customer.email) { %><div class="text-muted" style="font-size:.82rem;"><%= p.customer.email %></div><% } %>
                        <% } else { %>—<% } %>
                      </td>
                      <td data-label="PPZ ID"><%= p.customer && p.customer.ppzId ? p.customer.ppzId : '–' %></td>
                      <td data-label="Contact"><%= p.customer && p.customer.contact ? p.customer.contact : '–' %></td>
                      <td class="num" data-label="Items"><%= r.itemCount %></td>
                      <td class="num" data-label="Total">$<%= (r.totalCents/100).toFixed(2) %></td>
                      <td data-label="Packed" class="text-muted"><%= fmtSg(p.packedAt || p.createdAt) %></td>
                      <td class="num" data-label="Age"><span class="text-danger"><strong><%= r.age %>d</strong></span></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            <% } %>
          </div>
        </div>
      <% } else { %>
        <div class="admin-panel">
          <div class="panel-head">
            <h3>Logs</h3>
            <span class="muted">
              <% if (scope === 'vendor') { %>
                Scans you ran or scans on orders containing your products
              <% } else { %>
                Most recent first · all vendors
              <% } %>
            </span>
          </div>
          <div class="panel-body">
            <% if (!logs.length) { %>
              <div class="cc-empty" style="margin:0; border:none; border-radius:0;">No scans logged yet.</div>
            <% } else { %>
              <div class="cc-logs">
                <% logs.forEach(log => { %>
                  <%
                  const cls = {
                    success: 'badge-status fulfilled',
                    duplicate: 'badge-status awaiting_payment',
                    unauthorized_vendor: 'badge-status cancelled',
                    not_found: 'badge-status cancelled',
                    invalid_state: 'badge-status awaiting_payment',
                  }[log.result] || 'badge-status';
                  %>
                  <details class="cc-log-row">
                    <summary>
                      <span class="cc-log-order">
                        <% if (log.order) { %>
                          <strong><a href="/admin/orders/<%= log.order.id %>" class="text-reset" onclick="event.stopPropagation()"><%= log.order.number %></a></strong>
                        <% } else { %>
                          <span class="text-muted"><%= log.scannedValue %></span>
                        <% } %>
                      </span>
                      <span class="cc-log-result"><span class="<%= cls %>"><%= log.result.replace(/_/g, ' ') %></span></span>
                    </summary>
                    <div class="cc-log-body">
                      <dl class="profile-dl">
                        <dt>By</dt>
                        <dd><%= log.scannedBy ? log.scannedBy.name : '—' %></dd>
                        <dt>Notes</dt>
                        <dd><%= log.notes || '—' %></dd>
                        <dt>When</dt>
                        <dd><%= fmtSg(log.createdAt) %></dd>
                      </dl>
                    </div>
                  </details>
                <% }); %>
              </div>
            <% } %>
          </div>
        </div>
      <% } %>

    </main>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
<%- include('../partials/foot') %>
