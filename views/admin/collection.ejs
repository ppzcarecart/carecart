<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<%
const isVendor = user.role === 'vendor';
const sidebar = isVendor ? '../partials/vendor-sidebar' : '../partials/admin-sidebar';
%>
<div class="container admin-shell">
  <div class="admin-layout">
    <%- include(sidebar, { activePath }) %>
    <main class="admin-main">

      <div class="admin-page-header">
        <div>
          <h1>Manage Collection</h1>
          <p class="lede">
            Scan a customer's collection QR with the camera. Verify the
            order, then mark it as collected.<% if (scope === 'vendor') { %>
            You can only scan orders that contain your products.<% } %>
          </p>
        </div>
      </div>

      <div class="admin-panel">
        <div class="panel-head">
          <h3>Scanner</h3>
          <span class="muted" id="scannerStatus">Idle</span>
        </div>
        <div class="panel-body padded">
          <div class="d-flex gap-2 flex-wrap mb-3">
            <button id="startBtn" class="cc-btn cc-btn-primary" onclick="ppz.collection.start()">
              Start camera
            </button>
            <button id="stopBtn" class="cc-btn cc-btn-outline" onclick="ppz.collection.stop()" disabled>
              Stop camera
            </button>
            <div class="d-flex align-items-center gap-2 ms-auto">
              <input id="manualInput" class="form-control" placeholder="Or type order number" style="max-width:240px;">
              <button class="cc-btn cc-btn-outline" onclick="ppz.collection.manual()">Look up</button>
            </div>
          </div>

          <div id="reader" style="max-width: 480px; margin: 0 auto; border-radius: 12px; overflow: hidden; background: #000; min-height: 60px;"></div>

          <div id="scanResult" class="mt-3" style="display:none;"></div>
        </div>
      </div>

      <div class="admin-panel">
        <div class="panel-head">
          <h3>Collection logs</h3>
          <span class="muted">
            <% if (scope === 'vendor') { %>
              Scans you ran or scans on orders containing your products
            <% } else { %>
              Most recent first · all vendors
            <% } %>
          </span>
        </div>
        <div class="panel-body">
          <% if (!logs.length) { %>
            <div class="cc-empty" style="margin:0; border:none; border-radius:0;">No scans logged yet.</div>
          <% } else { %>
            <table class="admin-table" data-mobile="cards">
              <thead>
                <tr>
                  <th>When</th>
                  <th>Order</th>
                  <th>Result</th>
                  <th>Scanned by</th>
                  <th>Notes</th>
                </tr>
              </thead>
              <tbody>
                <% logs.forEach(log => { %>
                  <%
                  const cls = {
                    success: 'badge-status fulfilled',
                    duplicate: 'badge-status awaiting_payment',
                    unauthorized_vendor: 'badge-status cancelled',
                    not_found: 'badge-status cancelled',
                    invalid_state: 'badge-status awaiting_payment',
                  }[log.result] || 'badge-status';
                  %>
                  <tr>
                    <td class="text-muted"><%= new Date(log.createdAt).toLocaleString() %></td>
                    <td data-label="Order">
                      <% if (log.order) { %>
                        <strong><a href="/admin/orders/<%= log.order.id %>" class="text-reset"><%= log.order.number %></a></strong>
                      <% } else { %>
                        <span class="text-muted"><%= log.scannedValue %></span>
                      <% } %>
                    </td>
                    <td data-label="Result"><span class="<%= cls %>"><%= log.result.replace(/_/g, ' ') %></span></td>
                    <td data-label="By"><%= log.scannedBy ? log.scannedBy.name : '—' %></td>
                    <td class="text-muted" data-label="Notes" style="font-size:.85rem;"><%= log.notes || '' %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>

    </main>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
<%- include('../partials/foot') %>
