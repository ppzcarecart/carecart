<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container py-4">
  <h1>Categories</h1>
  <form id="newCat" class="row g-2 mb-4">
    <div class="col-md-4"><input class="form-control" name="name" placeholder="Name" required></div>
    <div class="col-md-4"><input class="form-control" name="slug" placeholder="slug (optional)"></div>
    <div class="col-md-4"><button class="btn btn-primary">Create</button></div>
  </form>
  <table class="table">
    <thead><tr><th>Name</th><th>Slug</th><th>Active</th><th></th></tr></thead>
    <tbody>
    <% categories.forEach(c => { %>
      <tr>
        <td><%= c.name %></td>
        <td><%= c.slug %></td>
        <td><%= c.active %></td>
        <td><button class="btn btn-sm btn-outline-danger" onclick="ppz.deleteCategory('<%= c.id %>')">Delete</button></td>
      </tr>
    <% }); %>
    </tbody>
  </table>
</div>
<script>
document.getElementById('newCat').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const body = { name: fd.get('name'), slug: fd.get('slug') || undefined };
  const res = await fetch('/api/categories', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
  if (res.ok) location.reload();
  else alert((await res.json()).message);
});
</script>
<%- include('../partials/foot') %>
