<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container admin-shell">
  <div class="admin-layout">
    <%- include('../partials/admin-sidebar', { activePath }) %>
    <main class="admin-main">

      <div class="admin-page-header">
        <div>
          <h1>Categories</h1>
          <p class="lede">Only admins and managers can create or edit categories. Vendors choose from this list.</p>
        </div>
      </div>

      <div class="admin-panel">
        <div class="panel-head"><h3>Add new</h3></div>
        <div class="panel-body padded">
          <form id="newCat" class="row g-2">
            <div class="col-md-5"><input class="form-control" name="name" placeholder="Category name" required></div>
            <div class="col-md-4"><input class="form-control" name="slug" placeholder="slug (optional)"></div>
            <div class="col-md-3"><button class="cc-btn cc-btn-primary cc-btn-block">Create category</button></div>
          </form>
        </div>
      </div>

      <div class="admin-panel">
        <div class="panel-body">
          <% if (!categories.length) { %>
            <div class="cc-empty" style="margin:0; border:none; border-radius:0;">No categories yet.</div>
          <% } else { %>
            <table class="admin-table">
              <thead><tr><th>Name</th><th>Slug</th><th>Status</th><th class="actions">Actions</th></tr></thead>
              <tbody>
              <% categories.forEach(c => { %>
                <tr>
                  <td><strong><%= c.name %></strong>
                    <% if (c.description) { %><div class="text-muted" style="font-size:.82rem"><%= c.description %></div><% } %>
                  </td>
                  <td><code><%= c.slug %></code></td>
                  <td><span class="tag <%= c.active ? 'tag-active' : 'tag-inactive' %>"><%= c.active ? 'active' : 'inactive' %></span></td>
                  <td class="actions"><button class="cc-btn cc-btn-ghost" style="padding:6px 10px; font-size:.85rem;" onclick="ppz.deleteCategory('<%= c.id %>')">Delete</button></td>
                </tr>
              <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>

    </main>
  </div>
</div>
<script>
document.getElementById('newCat').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const body = { name: fd.get('name'), slug: fd.get('slug') || undefined };
  const res = await fetch('/api/categories', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
  if (res.ok) location.reload();
  else alert((await res.json()).message);
});
</script>
<%- include('../partials/foot') %>
