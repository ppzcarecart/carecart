<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container py-4">
  <h1>Admin dashboard</h1>
  <div class="row g-3 my-3">
    <div class="col-md-3"><div class="card text-bg-light"><div class="card-body"><div class="text-muted small">Users</div><div class="h3"><%= counts.users %></div></div></div></div>
    <div class="col-md-3"><div class="card text-bg-light"><div class="card-body"><div class="text-muted small">Products</div><div class="h3"><%= counts.products %></div></div></div></div>
    <div class="col-md-3"><div class="card text-bg-light"><div class="card-body"><div class="text-muted small">Categories</div><div class="h3"><%= counts.categories %></div></div></div></div>
    <div class="col-md-3"><div class="card text-bg-light"><div class="card-body"><div class="text-muted small">Orders</div><div class="h3"><%= counts.orders %></div></div></div></div>
  </div>
  <div class="d-flex gap-2 mb-3">
    <a class="btn btn-outline-dark" href="/admin/users">Users</a>
    <a class="btn btn-outline-dark" href="/admin/products">Products</a>
    <a class="btn btn-outline-dark" href="/admin/categories">Categories</a>
    <a class="btn btn-outline-dark" href="/admin/orders">Orders</a>
    <a class="btn btn-outline-dark" href="/admin/import">Bulk import customers</a>
  </div>
  <h3>Recent orders</h3>
  <table class="table">
    <thead><tr><th>Number</th><th>Customer</th><th>Status</th><th>Total</th><th>Created</th></tr></thead>
    <tbody>
      <% orders.forEach(o => { %>
        <tr>
          <td><%= o.number %></td>
          <td><%= o.customer ? o.customer.email : '-' %></td>
          <td><span class="badge bg-secondary"><%= o.status %></span></td>
          <td>$<%= (o.totalCents/100).toFixed(2) %></td>
          <td><%= new Date(o.createdAt).toLocaleString() %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<%- include('../partials/foot') %>
