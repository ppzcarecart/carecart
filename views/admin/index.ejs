<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container admin-shell">
  <div class="admin-layout">
    <%- include('../partials/admin-sidebar', { activePath }) %>
    <main class="admin-main">

      <div class="admin-page-header">
        <div>
          <h1>Dashboard</h1>
          <p class="lede">Welcome back, <%= user.name %>. Here's what's happening across the marketplace.</p>
        </div>
        <div class="d-flex gap-2">
          <a href="/admin/products" class="cc-btn cc-btn-outline">Manage products</a>
          <a href="/admin/users" class="cc-btn cc-btn-primary">Manage users</a>
        </div>
      </div>

      <div class="admin-stats">
        <div class="admin-stat">
          <div class="stat-icon tone-brand">$</div>
          <div>
            <div class="stat-label">Revenue</div>
            <div class="stat-value">$<%= (counts.revenueCents/100).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
          </div>
        </div>
        <div class="admin-stat">
          <div class="stat-icon tone-blue">⌘</div>
          <div>
            <div class="stat-label">Orders</div>
            <div class="stat-value"><%= counts.orders %></div>
          </div>
        </div>
        <div class="admin-stat">
          <div class="stat-icon tone-amber">⏱</div>
          <div>
            <div class="stat-label">Pending</div>
            <div class="stat-value"><%= counts.pending %></div>
          </div>
        </div>
        <div class="admin-stat">
          <div class="stat-icon tone-violet">▣</div>
          <div>
            <div class="stat-label">Products</div>
            <div class="stat-value"><%= counts.products %></div>
          </div>
        </div>
        <div class="admin-stat">
          <div class="stat-icon tone-rose">★</div>
          <div>
            <div class="stat-label">Featured</div>
            <div class="stat-value"><%= counts.featured %> / 8</div>
          </div>
        </div>
        <div class="admin-stat">
          <div class="stat-icon tone-blue">◉</div>
          <div>
            <div class="stat-label">Vendors</div>
            <div class="stat-value"><%= counts.vendors %></div>
          </div>
        </div>
        <div class="admin-stat">
          <div class="stat-icon tone-brand">◉</div>
          <div>
            <div class="stat-label">Customers</div>
            <div class="stat-value"><%= counts.customers %></div>
          </div>
        </div>
        <div class="admin-stat">
          <div class="stat-icon tone-violet">◇</div>
          <div>
            <div class="stat-label">Categories</div>
            <div class="stat-value"><%= counts.categories %></div>
          </div>
        </div>
      </div>

      <div class="admin-panel">
        <div class="panel-head">
          <h3>Recent orders</h3>
          <a href="/admin/orders" class="muted">View all →</a>
        </div>
        <div class="panel-body">
          <% if (!orders.length) { %>
            <div class="cc-empty" style="margin: 0; border: none; border-radius: 0;">No orders yet.</div>
          <% } else { %>
            <table class="admin-table">
              <thead>
                <tr><th>Number</th><th>Customer</th><th>CType</th><th>Status</th><th class="num">Total</th><th>Created</th></tr>
              </thead>
              <tbody>
                <% orders.forEach(o => { %>
                  <% const ctype = o.customer ? (o.customer.ppzId ? 'PPZ' : 'CC') : 'NA'; %>
                  <tr>
                    <td><strong><a href="/admin/orders/<%= o.id %>" class="text-reset"><%= o.number %></a></strong></td>
                    <td><%= o.customer ? o.customer.email : '-' %></td>
                    <td>
                      <% if (ctype === 'NA') { %>
                        <span class="text-muted">—</span>
                      <% } else { %>
                        <span class="ctype-tag ctype-<%= ctype.toLowerCase() %>"><%= ctype %></span>
                      <% } %>
                    </td>
                    <td><span class="badge-status <%= o.status %>"><%= o.status %></span></td>
                    <td class="num">$<%= (o.totalCents/100).toFixed(2) %></td>
                    <td class="text-muted"><%= new Date(o.createdAt).toLocaleString() %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>

    </main>
  </div>
</div>
<%- include('../partials/foot') %>
