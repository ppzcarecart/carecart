<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<%
const sidebar = isAdmin ? '../partials/admin-sidebar' : '../partials/vendor-sidebar';
const baseHref = isAdmin ? '/admin/packings' : '/vendor/packings';
const tabs = [
  { k: 'open',   label: 'Open' },
  { k: 'packed', label: 'Packed' },
];
%>
<div class="container admin-shell">
  <div class="admin-layout">
    <%- include(sidebar, { activePath }) %>
    <main class="admin-main">

      <div class="admin-page-header">
        <div>
          <h1>Packings</h1>
          <p class="lede">
            One bundle per customer. Delivery and self-collection items
            are kept on separate sub-bundles so the right items go down
            the right fulfilment lane.
          </p>
        </div>
      </div>

      <div class="admin-panel" style="margin-bottom: 14px;">
        <div class="panel-body padded">
          <div class="d-flex flex-wrap gap-2 align-items-center cc-filter-rail" id="packingsTabs">
            <span class="text-muted" style="font-size:.78rem; text-transform:uppercase; letter-spacing:.04em;">Show</span>
            <% tabs.forEach(function(t) { %>
              <a href="<%= baseHref %>?status=<%= t.k %>"
                class="cc-btn <%= activeStatus === t.k ? 'cc-btn-primary' : 'cc-btn-outline' %>"
                style="padding:6px 14px; font-size:.85rem;">
                <%= t.label %>
              </a>
            <% }); %>
            <span class="text-muted" style="font-size:.85rem;"> · <%= rows.length %> customer<%= rows.length === 1 ? '' : 's' %></span>
          </div>
          <script>
            (function () {
              const active = document.querySelector('#packingsTabs .cc-btn-primary');
              if (active && active.scrollIntoView) {
                active.scrollIntoView({ inline: 'center', block: 'nearest' });
              }
            })();
          </script>
        </div>
      </div>

      <div class="admin-panel">
        <div class="panel-body">
          <% if (!rows.length) { %>
            <div class="cc-empty" style="margin:0; border:none; border-radius:0;">
              <% if (activeStatus === 'open') { %>
                No open packings. As paid orders come in they'll appear
                here grouped by customer.
              <% } else { %>
                Nothing has been marked packed yet.
              <% } %>
            </div>
          <% } else { %>
            <table class="admin-table" data-mobile="cards">
              <thead>
                <tr>
                  <th>Customer</th>
                  <th>PPZ ID</th>
                  <th class="num">Team</th>
                  <th>Contact</th>
                  <th>Type</th>
                  <th class="num">Items</th>
                  <th class="num">Orders</th>
                  <th><%= activeStatus === 'packed' ? 'Packed' : 'Updated' %></th>
                  <th class="actions">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% rows.forEach(r => {
                  const customer = r.customer;
                  const customerName = customer ? customer.name : '—';
                  const customerEmail = customer ? customer.email : '';
                  const customerPpz = customer && customer.ppzId ? customer.ppzId : '–';
                  const customerTeam = customer && customer.team != null ? customer.team : '–';
                  const customerContact = customer && customer.contact ? customer.contact : '–';
                  const ts = activeStatus === 'packed' && r.earliestPackedAt ? r.earliestPackedAt : r.latestUpdatedAt;
                  const detailHref = (isAdmin ? '/admin/packings/customer/' : '/vendor/packings/customer/') + r.customerId + '?status=' + activeStatus;
                  const methods = r.fulfilmentMethods.length
                    ? r.fulfilmentMethods
                    : ['collection'];
                %>
                  <tr id="packing-row-<%= r.customerId %>">
                    <td data-label="Customer">
                      <strong><a href="<%= detailHref %>" class="text-reset"><%= customerName %></a></strong>
                      <% if (customerEmail) { %>
                        <div class="text-muted" style="font-size:.82rem;"><%= customerEmail %></div>
                      <% } %>
                    </td>
                    <td data-label="PPZ ID"><%= customerPpz %></td>
                    <td class="num" data-label="Team"><%= customerTeam %></td>
                    <td data-label="Contact"><%= customerContact %></td>
                    <td data-label="Type">
                      <% methods.forEach(function(m, i) { %>
                        <% if (i > 0) { %> <% } %>
                        <span class="ftype-tag ftype-<%= m === 'delivery' ? 'd' : 'c' %>"><%= m === 'delivery' ? 'Delivery' : 'Collection' %></span>
                      <% }); %>
                    </td>
                    <td class="num" data-label="Items"><%= r.itemCount %></td>
                    <td class="num" data-label="Orders"><%= r.orderCount %></td>
                    <td data-label="<%= activeStatus === 'packed' ? 'Packed' : 'Updated' %>" class="text-muted">
                      <%= ts ? fmtSg(ts) : '—' %>
                    </td>
                    <td class="actions">
                      <a href="<%= detailHref %>" class="cc-btn cc-btn-outline" style="padding:6px 12px; font-size:.82rem;">View</a>
                      <% if (activeStatus === 'open') { %>
                        <button class="cc-btn cc-btn-primary" style="padding:6px 12px; font-size:.82rem;"
                          onclick="ppz.markPackedForCustomer('<%= r.customerId %>', this)">
                          Mark packed
                        </button>
                      <% } else { %>
                        <span class="tag tag-active">Packed</span>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>

    </main>
  </div>
</div>
<%- include('../partials/foot') %>
