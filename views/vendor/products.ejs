<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container admin-shell">
  <div class="admin-layout">
    <%- include('../partials/vendor-sidebar', { activePath }) %>
    <main class="admin-main">

      <div class="admin-page-header">
        <div>
          <h1>My products<% if (typeof lowStockOnly !== 'undefined' && lowStockOnly) { %> <span class="text-muted" style="font-size:.6em;">· Low stock</span><% } %></h1>
          <p class="lede">
            <% if (typeof lowStockOnly !== 'undefined' && lowStockOnly) { %>
              Showing items with ≤ 5 stock on hand. <a href="/vendor/products">Show all</a>.
            <% } else { %>
              Manage stock, variants, and add new items. Only you can edit products that you own.
            <% } %>
          </p>
        </div>
        <a href="/vendor/products/new" class="cc-btn cc-btn-primary">+ Add product</a>
      </div>

      <div class="admin-panel">
        <div class="panel-body">
          <% if (!products.length) { %>
            <div class="cc-empty" style="margin:0; border:none; border-radius:0;">You haven't added any products yet.</div>
          <% } else { %>
            <table class="admin-table" data-mobile="cards">
              <thead>
                <tr>
                  <th>Product</th>
                  <th class="num">Price</th>
                  <th class="num">Points</th>
                  <th class="num">Stock</th>
                  <th class="num">Variants</th>
                  <th>Status</th>
                  <th class="actions">Actions</th>
                </tr>
              </thead>
              <tbody>
              <% products.forEach(p => { %>
                <tr>
                  <td>
                    <div class="row-thumb">
                      <div class="thumb"><%- include('../partials/product-thumb', { product: p }) %></div>
                      <div class="meta">
                        <strong><a href="/p/<%= p.slug %>" class="text-reset" target="_blank"><%= p.name %></a></strong>
                        <% if (p.category) { %><div class="sub"><%= p.category.name %></div><% } %>
                      </div>
                    </div>
                  </td>
                  <td class="num" data-label="Price">$<%= (p.priceCents/100).toFixed(2) %></td>
                  <td class="num" data-label="Points"><%= p.pointsPrice ?? '–' %></td>
                  <td class="num" data-label="Stock"><%= p.stock %></td>
                  <td class="num" data-label="Variants"><%= (p.variants || []).length %></td>
                  <td data-label="Status">
                    <label class="cc-switch">
                      <input type="checkbox" <%= p.active ? 'checked' : '' %>
                        onchange="ppz.setActive('<%= p.id %>', this.checked, this)">
                      <span class="cc-switch-slider"></span>
                    </label>
                  </td>
                  <td class="actions">
                    <a href="/vendor/products/<%= p.id %>/edit" class="cc-btn cc-btn-outline" style="padding:6px 14px; font-size:.85rem;">Edit</a>
                    <button class="cc-btn cc-btn-ghost" style="padding:6px 10px; font-size:.85rem;" onclick="ppz.deleteProduct('<%= p.id %>')">Delete</button>
                  </td>
                </tr>
              <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>

    </main>
  </div>
</div>

<%- include('../partials/foot') %>
