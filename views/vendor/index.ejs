<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<div class="container admin-shell">
  <div class="admin-layout">
    <%- include('../partials/vendor-sidebar', { activePath }) %>
    <main class="admin-main">

      <div class="admin-page-header">
        <div>
          <h1>Vendor dashboard</h1>
          <p class="lede">Welcome, <%= user.vendorStoreName || user.name %>. Track sales, stock, and orders for your products.</p>
        </div>
        <a href="/vendor/products" class="cc-btn cc-btn-primary">Manage products</a>
      </div>

      <div class="admin-stats">
        <div class="admin-stat">
          <div class="stat-icon tone-brand">$</div>
          <div>
            <div class="stat-label">Revenue</div>
            <div class="stat-value">$<%= (stats.totalRevenueCents/100).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
          </div>
        </div>
        <div class="admin-stat">
          <div class="stat-icon tone-blue">⌘</div>
          <div>
            <div class="stat-label">Orders</div>
            <div class="stat-value"><%= stats.orderCount %></div>
          </div>
        </div>
        <div class="admin-stat">
          <div class="stat-icon tone-violet">▣</div>
          <div>
            <div class="stat-label">Units sold</div>
            <div class="stat-value"><%= stats.totalUnits %></div>
          </div>
        </div>
        <div class="admin-stat">
          <div class="stat-icon tone-rose">▣</div>
          <div>
            <div class="stat-label">Active products</div>
            <div class="stat-value"><%= stats.productCount %></div>
          </div>
        </div>
        <div class="admin-stat">
          <div class="stat-icon tone-amber">⚠</div>
          <div>
            <div class="stat-label">Low stock</div>
            <div class="stat-value"><%= stats.lowStockCount %></div>
          </div>
        </div>
      </div>

      <div class="admin-panel">
        <div class="panel-head">
          <h3>Sales by product</h3>
          <span class="muted">From paid &amp; fulfilled orders</span>
        </div>
        <div class="panel-body">
          <% if (!sales.length) { %>
            <div class="cc-empty" style="margin:0; border:none; border-radius:0;">No sales yet — share your store to get started.</div>
          <% } else { %>
            <table class="admin-table" data-mobile="cards">
              <thead>
                <tr><th>Product</th><th class="num">Units sold</th><th class="num">Revenue</th><th class="num">Points collected</th></tr>
              </thead>
              <tbody>
                <% sales.forEach(s => { %>
                  <tr>
                    <td><strong><%= s.productName %></strong></td>
                    <td class="num" data-label="Units sold"><%= s.unitsSold %></td>
                    <td class="num" data-label="Revenue">$<%= (s.revenueCents/100).toFixed(2) %></td>
                    <td class="num" data-label="Points"><%= s.pointsCollected || '–' %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>

      <div class="admin-panel">
        <div class="panel-head">
          <h3>Recent orders containing your items</h3>
        </div>
        <div class="panel-body">
          <% if (!orders.length) { %>
            <div class="cc-empty" style="margin:0; border:none; border-radius:0;">No orders yet.</div>
          <% } else { %>
            <table class="admin-table" data-mobile="cards">
              <thead><tr><th>Number</th><th>Customer</th><th>CType</th><th>Status</th><th class="num">Total</th><th>Created</th></tr></thead>
              <tbody>
              <% orders.slice(0, 12).forEach(o => { %>
                <% const ctype = o.customer ? (o.customer.ppzId ? 'PPZ' : 'CC') : 'NA'; %>
                <tr>
                  <td><strong><a href="/vendor/orders/<%= o.id %>" class="text-reset"><%= o.number %></a></strong></td>
                  <td data-label="Customer"><%= o.customer ? (o.customer.name || o.customer.email) : '-' %></td>
                  <td data-label="Type">
                    <% if (ctype === 'NA') { %>
                      <span class="text-muted">—</span>
                    <% } else { %>
                      <span class="ctype-tag ctype-<%= ctype.toLowerCase() %>"><%= ctype %></span>
                    <% } %>
                  </td>
                  <td data-label="Status"><span class="badge-status <%= o.status %>"><%= o.status %></span></td>
                  <td class="num" data-label="Total">$<%= (o.totalCents/100).toFixed(2) %></td>
                  <td class="text-muted" data-label="Created"><%= new Date(o.createdAt).toLocaleString() %></td>
                </tr>
              <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>

    </main>
  </div>
</div>
<%- include('../partials/foot') %>
