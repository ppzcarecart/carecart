<%- include('partials/head') %>
<%- include('partials/nav') %>
<%
const isCustomer = user.role === 'customer';
const canRefund =
  !isCustomer &&
  order.status !== 'refunded' &&
  (user.role === 'admin' || user.role === 'manager' ||
    (user.role === 'vendor' && (order.items || []).some(i => i.vendorId === user.id)));
%>
<div class="container admin-shell">
  <div class="<%= isCustomer ? '' : 'admin-layout' %>">
    <% if (user.role === 'vendor') { %>
      <%- include('partials/vendor-sidebar', { activePath }) %>
    <% } else if (!isCustomer) { %>
      <%- include('partials/admin-sidebar', { activePath }) %>
    <% } %>
    <main class="admin-main">

      <div class="admin-page-header">
        <div>
          <h1>Order <%= order.number %></h1>
          <p class="lede"><a href="<%= returnTo %>">← Back</a> · placed <%= new Date(order.createdAt).toLocaleString() %></p>
        </div>
        <div class="d-flex align-items-center gap-2">
          <span class="badge-status <%= order.status %>" style="font-size:.85rem; padding:6px 14px;"><%= order.status %></span>
          <% if (canRefund) { %>
            <button class="cc-btn cc-btn-outline" style="padding:6px 14px; font-size:.85rem; color:#b91c1c; border-color:#fca5a5;"
              data-bs-toggle="modal" data-bs-target="#refundModal">
              Issue refund
            </button>
          <% } %>
        </div>
      </div>

      <%
      const ctype = (customer && customer.ppzId) ? 'PPZ' : (customer ? 'CC' : 'NA');
      const ctypeLabel = ctype === 'NA' ? '—' : ctype;
      %>

      <div class="admin-panel">
        <div class="panel-head">
          <h3>Customer</h3>
          <span class="ctype-tag ctype-<%= ctype.toLowerCase() %>"><%= ctypeLabel %></span>
        </div>
        <div class="panel-body padded">
          <% if (customer) { %>
            <dl class="profile-dl">
              <dt>Name</dt>
              <dd><%= customer.name %></dd>
              <dt>Email</dt>
              <dd><%= customer.email %></dd>
              <% if (customer.contact) { %>
                <dt>Contact</dt>
                <dd><%= customer.contact %></dd>
              <% } %>
              <% if (customer.ppzId) { %>
                <dt>PPZ ID</dt>
                <dd><%= customer.ppzId %></dd>
              <% } %>
              <% if (customer.team != null) { %>
                <dt>Team</dt>
                <dd><%= customer.team %></dd>
              <% } %>
              <dt>Member since</dt>
              <dd><%= new Date(customer.createdAt).toLocaleDateString() %></dd>
            </dl>

            <h4 style="margin-top:22px; font-size:.95rem; font-weight:600;">
              Fulfilment · <span class="text-muted" style="font-weight:500;"><%= order.fulfilmentMethod === 'collection' ? 'Self-collection' : 'Delivery' %></span>
            </h4>
            <% if (order.fulfilmentMethod === 'collection') { %>
              <% if (order.collectionPoints && order.collectionPoints.length) { %>
                <% order.collectionPoints.forEach(cp => { %>
                  <div style="margin-top:8px;">
                    <strong><%= cp.vendorName || 'PPZ Collection Point' %></strong>
                    <% if (cp.source === 'vendor') { %>
                      <span class="ctype-tag ctype-ppz" style="margin-left:6px;">Vendor location</span>
                    <% } %>
                    <div><%= cp.line1 || '' %></div>
                    <% if (cp.line2) { %><div><%= cp.line2 %></div><% } %>
                    <% if (cp.postalCode) { %><div class="text-muted">Postal <%= cp.postalCode %></div><% } %>
                    <% if (cp.contact) { %><div class="text-muted">Contact <%= cp.contact %></div><% } %>
                    <% if (cp.hours) { %><div class="text-muted">Hours <%= cp.hours %></div><% } %>
                  </div>
                <% }); %>
              <% } else { %>
                <p class="text-muted" style="margin:0;">No collection point recorded.</p>
              <% } %>
            <% } else if (order.shippingAddress && order.shippingAddress.line1) { %>
              <p style="margin:0;"><%= order.shippingAddress.line1 %></p>
              <% if (order.shippingAddress.line2) { %>
                <p style="margin:0;"><%= order.shippingAddress.line2 %></p>
              <% } %>
              <% const region = [order.shippingAddress.city, order.shippingAddress.state, order.shippingAddress.postalCode].filter(Boolean).join(' '); %>
              <% if (region) { %><p class="text-muted" style="margin:0;"><%= region %></p><% } %>
              <% if (order.shippingAddress.country) { %>
                <p class="text-muted" style="margin:0;"><%= order.shippingAddress.country %></p>
              <% } %>
            <% } else if (customer.addresses && customer.addresses.length) { %>
              <% const a = customer.addresses.find(x => x.isDefault) || customer.addresses[0]; %>
              <p style="margin:0;"><%= a.line1 %></p>
              <% if (a.line2) { %><p style="margin:0;"><%= a.line2 %></p><% } %>
              <% const region = [a.city, a.state, a.postalCode].filter(Boolean).join(' '); %>
              <% if (region) { %><p class="text-muted" style="margin:0;"><%= region %></p><% } %>
              <% if (a.country) { %><p class="text-muted" style="margin:0;"><%= a.country %></p><% } %>
            <% } else { %>
              <p class="text-muted" style="margin:0;">No address on file.</p>
            <% } %>
          <% } else { %>
            <p class="text-muted" style="margin:0;">Customer record no longer available.</p>
          <% } %>
        </div>
      </div>

      <div class="admin-panel">
        <div class="panel-head">
          <h3>Items <span class="muted">(<%= order.items.length %>)</span></h3>
        </div>
        <div class="panel-body">
          <table class="admin-table" data-mobile="cards">
            <thead>
              <tr>
                <th>Product</th>
                <th>Vendor</th>
                <th class="num">Qty</th>
                <th>Mode</th>
                <th class="num">Unit</th>
                <th class="num">Line total</th>
              </tr>
            </thead>
            <tbody>
              <% order.items.forEach(it => { %>
                <tr>
                  <td>
                    <strong><%= it.productName %></strong>
                    <% if (it.product) { %>
                      <div class="text-muted" style="font-size:.82rem">
                        <a href="/p/<%= it.product.slug %>" target="_blank" class="text-muted">View on shop ↗</a>
                      </div>
                    <% } %>
                  </td>
                  <td data-label="Vendor"><%= it.vendor ? (it.vendor.vendorStoreName || it.vendor.name) : '—' %></td>
                  <td class="num" data-label="Qty"><%= it.quantity %></td>
                  <td data-label="Mode">
                    <span class="tag <%= it.pricingMode === 'points' ? 'tag-vendor' : 'tag-customer' %>"><%= it.pricingMode %></span>
                  </td>
                  <td class="num" data-label="Unit">
                    <% if (it.pricingMode === 'price') { %>
                      $<%= (it.unitPriceCents/100).toFixed(2) %>
                    <% } else { %>
                      <% if (it.unitPriceCents > 0) { %>$<%= (it.unitPriceCents/100).toFixed(2) %> + <% } %>
                      <%= Number(it.unitPoints).toLocaleString() %> pts
                    <% } %>
                  </td>
                  <td class="num" data-label="Line total">
                    <% const lineCash = it.unitPriceCents * it.quantity; %>
                    <% const linePoints = it.unitPoints * it.quantity; %>
                    <% if (it.pricingMode === 'price') { %>
                      $<%= (lineCash/100).toFixed(2) %>
                    <% } else { %>
                      <% if (lineCash > 0) { %>$<%= (lineCash/100).toFixed(2) %> + <% } %>
                      <%= Number(linePoints).toLocaleString() %> pts
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>

      <% if (order.status === 'refunded' && order.refundReason) { %>
        <div class="admin-panel">
          <div class="panel-head">
            <h3>Remarks</h3>
            <span class="muted">Refund reason</span>
          </div>
          <div class="panel-body padded">
            <p style="margin:0; white-space:pre-wrap;"><%= order.refundReason %></p>
          </div>
        </div>
      <% } %>

      <% if (order.collectedAt) { %>
        <div class="admin-panel">
          <div class="panel-head">
            <h3>Collection</h3>
            <span class="muted">Picked up</span>
          </div>
          <div class="panel-body padded">
            <p style="margin:0;">
              <strong><%= new Date(order.collectedAt).toLocaleString() %></strong>
              <% if (order.collectedBy) { %>
                · marked by <%= order.collectedBy.name %>
              <% } %>
            </p>
          </div>
        </div>
      <% } else if (order.fulfilmentMethod === 'collection' && (order.status === 'paid' || order.status === 'fulfilled') && isCustomer) { %>
        <div class="admin-panel">
          <div class="panel-body padded" style="text-align:center;">
            <a href="/orders/<%= order.id %>/qr" class="cc-btn cc-btn-primary">
              Show collection QR
            </a>
            <div class="text-muted mt-2" style="font-size:.85rem;">
              Show this QR at the counter to collect your order.
            </div>
          </div>
        </div>
      <% } %>

      <div class="admin-panel" style="max-width: 480px; margin-left: auto;">
        <div class="panel-body padded">
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Cash subtotal</span>
            <strong>$<%= (order.subtotalCents/100).toFixed(2) %></strong>
          </div>
          <% if (order.deliveryFeeCents > 0) { %>
            <div class="d-flex justify-content-between mb-2">
              <span class="text-muted">Delivery</span>
              <strong>$<%= (order.deliveryFeeCents/100).toFixed(2) %></strong>
            </div>
          <% } %>
          <% if (order.pointsTotal > 0) { %>
            <div class="d-flex justify-content-between mb-2">
              <span class="text-muted">Points subtotal</span>
              <strong><%= Number(order.pointsTotal).toLocaleString() %> pts</strong>
            </div>
          <% } %>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Payment</span>
            <span><%= order.paymentProvider || '—' %></span>
          </div>
          <hr>
          <div class="d-flex justify-content-between" style="font-size:1.05rem;">
            <strong>Total</strong>
            <strong>
              $<%= (order.totalCents/100).toFixed(2) %><% if (order.pointsTotal > 0) { %> + <%= Number(order.pointsTotal).toLocaleString() %> pts<% } %>
            </strong>
          </div>
        </div>
      </div>

    </main>
  </div>
</div>

<% if (canRefund) { %>
  <div class="modal fade" id="refundModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <form id="refundForm" onsubmit="event.preventDefault(); ppz.submitRefund(this, '<%= order.id %>')">
          <div class="modal-header">
            <h5>Issue refund · <%= order.number %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p class="text-muted" style="font-size:.9rem;">
              <% if (order.pointsTotal > 0) { %>
                <%= Number(order.pointsTotal).toLocaleString() %> PPZ points will be returned to the customer with the description below in their transaction history.
              <% } else { %>
                The order status will be locked to <strong>refunded</strong>. Cash refunds need to be settled with the payment provider separately.
              <% } %>
            </p>
            <div class="mb-2">
              <label>Reason <span class="text-danger">*</span></label>
              <textarea class="form-control" name="reason" rows="3" maxlength="500" required
                placeholder="e.g. Customer reported damaged item — replacement out of stock"></textarea>
              <small class="text-muted">Visible to admin/manager/vendor under <em>Remarks</em>; included in the customer's PPZ history when points are refunded.</small>
            </div>
            <div id="refundError" class="text-danger small" style="min-height:1.2em;"></div>
          </div>
          <div class="modal-footer">
            <button type="button" class="cc-btn cc-btn-ghost" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="cc-btn cc-btn-primary" style="background:#b91c1c; border-color:#b91c1c;">
              Confirm refund
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
<% } %>

<%- include('partials/foot') %>
