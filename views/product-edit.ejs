<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="container admin-shell">
  <div class="admin-layout">
    <% if (user.role === 'vendor') { %>
      <%- include('partials/vendor-sidebar', { activePath }) %>
    <% } else { %>
      <%- include('partials/admin-sidebar', { activePath }) %>
    <% } %>
    <main class="admin-main" data-product-id="<%= product.id %>">

      <div class="admin-page-header">
        <div>
          <h1>Edit product</h1>
          <p class="lede"><a href="<%= returnTo %>">← Back to list</a></p>
        </div>
        <div class="d-flex gap-2">
          <a href="/p/<%= product.slug %>" class="cc-btn cc-btn-outline" target="_blank">View on shop</a>
          <button class="cc-btn cc-btn-primary" onclick="ppz.saveProduct()">Save changes</button>
        </div>
      </div>

      <div class="admin-panel">
        <div class="panel-head"><h3>Details</h3></div>
        <div class="panel-body padded">
          <form id="productForm" onsubmit="event.preventDefault(); ppz.saveProduct();">
            <div class="row">
              <div class="col-md-8 mb-3">
                <label>Product name</label>
                <input class="form-control" name="name" value="<%= product.name %>" required>
              </div>
              <div class="col-md-2 mb-3">
                <label>Active</label>
                <select class="form-select" name="active">
                  <option value="true"  <%= product.active ? 'selected' : '' %>>Active</option>
                  <option value="false" <%= !product.active ? 'selected' : '' %>>Inactive</option>
                </select>
              </div>
              <div class="col-md-2 mb-3">
                <label title="Lower numbers display first in the storefront. Default 0.">Display order</label>
                <input type="number" min="0" step="1" class="form-control" name="sortOrder"
                  value="<%= product.sortOrder ?? 0 %>" placeholder="0">
              </div>
            </div>
            <div class="mb-3">
              <label>Description</label>
              <textarea class="form-control" name="description" rows="3"><%= product.description || '' %></textarea>
            </div>
            <div class="row">
              <div class="col-md-3 mb-3">
                <label>Normal price (SGD) <span class="text-danger">*</span></label>
                <div class="input-group">
                  <span class="input-group-text">$</span>
                  <input type="number" step="0.01" min="0" class="form-control" name="price"
                    value="<%= (product.priceCents/100).toFixed(2) %>" required>
                </div>
              </div>
              <div class="col-md-3 mb-3">
                <label>PPZ member price (SGD)</label>
                <div class="input-group">
                  <span class="input-group-text">$</span>
                  <input type="number" step="0.01" min="0" class="form-control" name="ppzPrice"
                    value="<%= product.ppzPriceCents != null ? (product.ppzPriceCents/100).toFixed(2) : '' %>"
                    placeholder="Blank → same as normal">
                </div>
              </div>
              <div class="col-md-3 mb-3">
                <label>Points price</label>
                <input type="number" min="0" step="1" class="form-control" name="pointsPrice" id="pointsPriceInput"
                  value="<%= product.pointsPrice ?? '' %>" placeholder="Blank to disable">
                <div class="form-check mt-2">
                  <input class="form-check-input" type="checkbox" id="allowPointsRedemption"
                    name="allowPointsRedemption" <%= product.allowPointsRedemption ? 'checked' : '' %>>
                  <label class="form-check-label" for="allowPointsRedemption" style="font-size:.82rem;">
                    Auto-calc from price · <span id="pointsPreview" class="text-muted">—</span>
                  </label>
                </div>
              </div>
              <div class="col-md-3 mb-3">
                <label>Stock</label>
                <input type="number" min="0" step="1" class="form-control" name="stock" value="<%= product.stock %>">
              </div>
            </div>
            <div class="row">
              <div class="col-md-8 mb-3">
                <label>Category</label>
                <select class="form-select" name="categoryId">
                  <option value="">— None —</option>
                  <% categories.forEach(c => { %>
                    <option value="<%= c.id %>" <%= product.categoryId === c.id ? 'selected' : '' %>><%= c.name %></option>
                  <% }); %>
                </select>
              </div>
              <div class="col-md-4 mb-3">
                <label>Delivery fee override (SGD)</label>
                <div class="input-group">
                  <span class="input-group-text">$</span>
                  <input type="number" step="0.01" min="0" class="form-control" name="deliveryFee"
                    value="<%= product.deliveryFeeCentsOverride != null ? (product.deliveryFeeCentsOverride/100).toFixed(2) : '' %>"
                    placeholder="Blank → use vendor / admin default">
                </div>
              </div>
            </div>
            <hr class="my-3">
            <p class="text-muted" style="font-size:.85rem; margin-bottom:14px;">
              Fulfilment options. Collection only forces customers into
              self-collection (Delivery is disabled at checkout for any
              cart with this item). The collection source picks the
              pickup location for this product specifically; the vendor
              default uses the vendor's own setting under
              <strong>Vendor settings</strong>.
            </p>
            <div class="row">
              <div class="col-md-5 mb-3">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="collectionOnly"
                    name="collectionOnly" <%= product.collectionOnly ? 'checked' : '' %>>
                  <label class="form-check-label" for="collectionOnly">
                    Collection only (no delivery)
                  </label>
                </div>
              </div>
              <div class="col-md-7 mb-3">
                <label>Collection location</label>
                <select class="form-select" name="collectionSource">
                  <option value="" <%= !product.collectionSource ? 'selected' : '' %>>Use vendor default</option>
                  <option value="admin" <%= product.collectionSource === 'admin' ? 'selected' : '' %>>Admin (PPZ Collection Point)</option>
                  <option value="vendor" <%= product.collectionSource === 'vendor' ? 'selected' : '' %>>Vendor's own location</option>
                </select>
              </div>
            </div>
          </form>
        </div>
      </div>

      <div class="admin-panel">
        <div class="panel-head">
          <h3>Images</h3>
          <span class="muted"><span id="imgCount"><%= (product.images || []).length %></span> / 8</span>
        </div>
        <div class="panel-body padded">
          <div class="image-grid" id="imageGrid">
            <% (product.images || []).forEach(img => { %>
              <div class="image-tile" data-image-id="<%= img.id %>" title="<%= img.url %>">
                <img src="<%= img.url %>" alt=""
                     data-fallback-bg="linear-gradient(135deg,#fee2e2,#fecaca)"
                     data-fallback-initial="!"
                     onerror="ppz.imgFallback(this); console.warn('[broken image]', this.dataset.failedUrl || <%- JSON.stringify(img.url) %>);">
                <button type="button" class="image-remove" title="Remove" onclick="ppz.removeProductImage('<%= img.id %>')">×</button>
                <a class="image-tile-url" href="<%= img.url %>" target="_blank" rel="noopener" title="Open in new tab to test">
                  <%= img.url.length > 36 ? img.url.slice(0, 33) + '…' : img.url %>
                </a>
              </div>
            <% }); %>
          </div>

          <label class="image-upload-zone" id="imageDropZone">
            <input type="file" id="imageInput" accept="image/*" multiple hidden>
            <span class="upload-icon">↥</span>
            <strong>Click to upload</strong>
            <span class="text-muted">or drop images here · PNG / JPG · up to 8 total</span>
          </label>
        </div>
      </div>

      <div class="admin-panel">
        <div class="panel-head">
          <h3>Variants</h3>
          <button class="cc-btn cc-btn-outline" style="padding:6px 14px; font-size:.85rem;" onclick="ppz.addVariantRow()">+ Add variant</button>
        </div>
        <div class="panel-body">
          <% if (!product.variants || product.variants.length === 0) { %>
            <div class="cc-empty" style="margin:0; border:none; border-radius:0;" id="noVariants">
              No variants yet. Add one above (size, color, pack, etc.) to track separate stock or pricing.
            </div>
          <% } %>
          <table class="admin-table" id="variantTable" <%= (!product.variants || product.variants.length === 0) ? 'hidden' : '' %>>
            <thead>
              <tr>
                <th>Image</th>
                <th>Name</th>
                <th>SKU</th>
                <th class="num">Price (SGD)</th>
                <th class="num">PPZ price (SGD)</th>
                <th class="num">Points</th>
                <th class="num">Stock</th>
                <th class="actions">Actions</th>
              </tr>
            </thead>
            <tbody id="variantBody">
              <% (product.variants || []).forEach(v => { %>
                <tr data-variant-id="<%= v.id %>">
                  <td>
                    <div class="variant-image-cell">
                      <div class="variant-image-thumb"
                           style="<%= v.imageUrl ? `background-image: url('${v.imageUrl}')` : '' %>"></div>
                      <input type="hidden" name="imageUrl" value="<%= v.imageUrl || '' %>">
                      <input type="file" accept="image/*" hidden onchange="ppz.uploadVariantImage(this)">
                      <button type="button" class="cc-btn cc-btn-ghost" style="padding:4px 8px; font-size:.72rem;"
                        onclick="this.previousElementSibling.click()">
                        <%= v.imageUrl ? 'Change' : 'Upload' %>
                      </button>
                    </div>
                  </td>
                  <td><input type="text" name="name" value="<%= v.name %>" placeholder="Size: M / Color: Black"></td>
                  <td><input type="text" name="sku" value="<%= v.sku || '' %>" placeholder="Optional SKU"></td>
                  <td class="num"><input type="number" step="0.01" min="0" name="priceOverride" value="<%= v.priceCentsOverride != null ? (v.priceCentsOverride/100).toFixed(2) : '' %>" placeholder="—"></td>
                  <td class="num"><input type="number" step="0.01" min="0" name="ppzPriceOverride" value="<%= v.ppzPriceCentsOverride != null ? (v.ppzPriceCentsOverride/100).toFixed(2) : '' %>" placeholder="—"></td>
                  <td class="num"><input type="number" min="0" step="1" name="pointsPriceOverride" value="<%= v.pointsPriceOverride ?? '' %>" placeholder="—"></td>
                  <td class="num"><input type="number" min="0" step="1" name="stock" value="<%= v.stock %>"></td>
                  <td class="actions">
                    <button class="cc-btn cc-btn-outline" style="padding:4px 10px; font-size:.78rem;" onclick="ppz.saveVariantRow(this)">Save</button>
                    <button class="cc-btn cc-btn-ghost" style="padding:4px 10px; font-size:.78rem;" onclick="ppz.deleteVariantRow(this)">Delete</button>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="d-flex justify-content-between align-items-center mt-3">
        <button class="cc-btn cc-btn-ghost text-danger" onclick="ppz.deleteFromEdit('<%= returnTo %>')">Delete product</button>
        <button class="cc-btn cc-btn-primary" onclick="ppz.saveProduct()">Save changes</button>
      </div>

    </main>
  </div>
</div>

<script>
  ppz._editPage = {
    productId: '<%= product.id %>',
    returnTo: '<%= returnTo %>',
    pointsPerDollar: <%= pointsPerDollar %>,
  };
  ppz.bindImageUpload();
  ppz.bindAllowPointsToggle();
</script>

<%- include('partials/foot') %>
