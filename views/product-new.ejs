<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="container admin-shell">
  <div class="admin-layout">
    <% if (user.role === 'vendor') { %>
      <%- include('partials/vendor-sidebar', { activePath }) %>
    <% } else { %>
      <%- include('partials/admin-sidebar', { activePath }) %>
    <% } %>
    <main class="admin-main">

      <div class="admin-page-header">
        <div>
          <h1>New product</h1>
          <p class="lede"><a href="<%= returnTo %>">← Back to list</a></p>
        </div>
        <div class="d-flex gap-2">
          <a href="<%= returnTo %>" class="cc-btn cc-btn-outline">Cancel</a>
          <button class="cc-btn cc-btn-primary" onclick="ppz.createProduct()">Create product</button>
        </div>
      </div>

      <div class="admin-panel">
        <div class="panel-head"><h3>Details</h3></div>
        <div class="panel-body padded">
          <form id="productForm" onsubmit="event.preventDefault(); ppz.createProduct();">
            <div class="row">
              <div class="col-md-8 mb-3">
                <label>Product name <span class="text-danger">*</span></label>
                <input class="form-control" name="name" required autofocus>
              </div>
              <div class="col-md-4 mb-3">
                <label>Active</label>
                <select class="form-select" name="active">
                  <option value="true" selected>Active</option>
                  <option value="false">Inactive</option>
                </select>
              </div>
            </div>
            <div class="mb-3">
              <label>Description</label>
              <textarea class="form-control" name="description" rows="3" placeholder="What makes this product great?"></textarea>
            </div>
            <div class="row">
              <div class="col-md-3 mb-3">
                <label>Normal price (SGD) <span class="text-danger">*</span></label>
                <div class="input-group">
                  <span class="input-group-text">$</span>
                  <input type="number" step="0.01" min="0" class="form-control" name="price" required placeholder="12.90">
                </div>
              </div>
              <div class="col-md-3 mb-3">
                <label>PPZ member price (SGD)</label>
                <div class="input-group">
                  <span class="input-group-text">$</span>
                  <input type="number" step="0.01" min="0" class="form-control" name="ppzPrice" placeholder="10.90">
                </div>
              </div>
              <div class="col-md-3 mb-3">
                <label>Points price</label>
                <input type="number" min="0" step="1" class="form-control" name="pointsPrice" placeholder="Blank to disable" id="pointsPriceInput">
                <div class="form-check mt-2">
                  <input class="form-check-input" type="checkbox" id="allowPointsRedemption" name="allowPointsRedemption">
                  <label class="form-check-label" for="allowPointsRedemption" style="font-size:.82rem;">
                    Auto-calc from price · <span id="pointsPreview" class="text-muted">—</span>
                  </label>
                </div>
              </div>
              <div class="col-md-3 mb-3">
                <label>Stock</label>
                <input type="number" min="0" step="1" class="form-control" name="stock" value="0">
              </div>
            </div>
            <div class="row">
              <% if (isAdmin) { %>
                <div class="col-md-6 mb-3">
                  <label>Fulfilment vendor</label>
                  <select class="form-select" name="vendorId" required>
                    <% vendors.forEach(v => { %>
                      <%
                      const isDefault = typeof defaultVendorId !== 'undefined' && v.id === defaultVendorId;
                      const label = isDefault ? `${v.vendorStoreName || v.name} (default)` : `${v.vendorStoreName || v.name} (${v.email})`;
                      %>
                      <option value="<%= v.id %>" <%= isDefault ? 'selected' : '' %>><%= label %></option>
                    <% }); %>
                  </select>
                  <small class="text-muted">Defaults to PPZ Fulfilment when you don't pick a third-party vendor.</small>
                </div>
              <% } %>
              <div class="col-md-<%= isAdmin ? '4' : '8' %> mb-3">
                <label>Category</label>
                <select class="form-select" name="categoryId">
                  <option value="">— None —</option>
                  <% categories.forEach(c => { %>
                    <option value="<%= c.id %>"><%= c.name %></option>
                  <% }); %>
                </select>
              </div>
              <div class="col-md-<%= isAdmin ? '4' : '4' %> mb-3">
                <label>Delivery fee override (SGD)</label>
                <div class="input-group">
                  <span class="input-group-text">$</span>
                  <input type="number" step="0.01" min="0" class="form-control" name="deliveryFee" placeholder="Blank → use vendor / admin default">
                </div>
              </div>
            </div>
            <hr class="my-3">
            <p class="text-muted" style="font-size:.85rem; margin-bottom:14px;">
              Fulfilment options. Collection only forces customers into
              self-collection (Delivery is disabled at checkout for any
              cart with this item). The collection source picks the
              pickup location for this product specifically; the vendor
              default uses the vendor's own setting under
              <strong>Vendor settings</strong>.
            </p>
            <div class="row">
              <div class="col-md-5 mb-3">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="collectionOnly" name="collectionOnly">
                  <label class="form-check-label" for="collectionOnly">
                    Collection only (no delivery)
                  </label>
                </div>
              </div>
              <div class="col-md-7 mb-3">
                <label>Collection location</label>
                <select class="form-select" name="collectionSource">
                  <option value="" selected>Use vendor default</option>
                  <option value="admin">Admin (PPZ Collection Point)</option>
                  <option value="vendor">Vendor's own location</option>
                </select>
              </div>
            </div>
          </form>
        </div>
      </div>

      <div class="admin-panel">
        <div class="panel-head">
          <h3>Images</h3>
          <span class="muted"><span id="imgCount">0</span> / 8</span>
        </div>
        <div class="panel-body padded">
          <div class="image-grid" id="imageGrid"></div>

          <label class="image-upload-zone" id="imageDropZone">
            <input type="file" id="imageInput" accept="image/*" multiple hidden>
            <span class="upload-icon">↥</span>
            <strong>Click to upload</strong>
            <span class="text-muted">or drop images here · PNG / JPG · up to 8 total</span>
          </label>
        </div>
      </div>

      <div class="admin-panel">
        <div class="panel-head">
          <h3>Variants</h3>
          <button class="cc-btn cc-btn-outline" style="padding:6px 14px; font-size:.85rem;" onclick="ppz.addVariantRow()">+ Add variant</button>
        </div>
        <div class="panel-body">
          <div class="cc-empty" style="margin:0; border:none; border-radius:0;" id="noVariants">
            No variants yet. Add one above (size, color, pack, etc.) to track separate stock or pricing.
          </div>
          <table class="admin-table" id="variantTable" hidden>
            <thead>
              <tr>
                <th>Name</th>
                <th>SKU</th>
                <th class="num">Price (SGD)</th>
                <th class="num">PPZ price (SGD)</th>
                <th class="num">Points</th>
                <th class="num">Stock</th>
                <th class="actions">Actions</th>
              </tr>
            </thead>
            <tbody id="variantBody"></tbody>
          </table>
        </div>
      </div>

      <div class="d-flex justify-content-end mt-3">
        <button class="cc-btn cc-btn-primary" onclick="ppz.createProduct()">Create product</button>
      </div>

    </main>
  </div>
</div>

<script>
  ppz._newPage = {
    returnTo: '<%= returnTo %>',
    isAdmin: <%= isAdmin ? 'true' : 'false' %>,
    pointsPerDollar: <%= pointsPerDollar %>,
    imageUrls: [],
  };
  ppz.bindImageUpload();
  ppz.bindAllowPointsToggle();
</script>

<%- include('partials/foot') %>
