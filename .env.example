# Server
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database (Railway will inject DATABASE_URL automatically)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/carecart
# Toggle SSL for managed DBs (Railway = true)
DATABASE_SSL=false

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# File uploads (Railway volume mount path, e.g. /data)
UPLOAD_DIR=./uploads

# Stripe (PayNow)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=sgd

# Points API (provided later by integrator)
POINTS_API_BASE_URL=
POINTS_API_KEY=

# Bootstrap admin (created on first boot if no admin exists)
BOOTSTRAP_ADMIN_EMAIL=admin@carecart.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!123
BOOTSTRAP_ADMIN_NAME=Administrator

# Set to "true" to populate demo categories, a demo vendor, and sample
# products with variants on boot. Idempotent — safe to leave on.
SEED_SAMPLES=false
